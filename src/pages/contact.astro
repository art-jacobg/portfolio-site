---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Contact | Jacob Gordillo" description="Get in touch" />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html, body {
        width: 100%;
        overflow-x: hidden;
        overflow-y: auto;
      }
      body {
        margin: 0;
        padding: 0 !important;
      }

      main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      .contact-video-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center center;
        z-index: 1;
        pointer-events: none;
      }
      .contact-video-bg.desktop { display: block; }

      /* Mobile background video lives OUTSIDE .contact-page entirely now —
         see the <video class="mobile-bg-video"> right after <body>.
         Hidden by default; only shown + pinned inside the mobile media query. */
      .mobile-bg-video { display: none; }

      .contact-page {
        position: relative;
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
      }

      .contact-wrap {
        position: relative;
        z-index: 2;
        width: min(1000px, 75vw);
        margin: 0 auto;
        padding-top: 132px;
        padding-bottom: 450px;
        transform: translateX(1rem);
        animation: fadeIn 500ms ease 200ms forwards;
        opacity: 0;
      }

      .page-title {
        font-family: "Superglue";
        font-size: clamp(4rem, 8vw, 6rem);
        color: white;
        position: absolute;
        top: 1rem;
        left: clamp(-24rem, -20vw, -18rem);
        margin: 0;
        z-index: 20;
        pointer-events: none;
      }

      .contact-animbox {
        position: relative;
        width: 100%;
        display: grid;
        padding: clamp(1.5rem, 3vw, 3rem);
        overflow: visible;
        margin-top: 4rem;
      }

      .contact-animbox-bg {
        position: absolute;
        inset: -8% 2%;
        width: 85%;
        height: 116%;
        object-fit: fill;
        z-index: 0;
        pointer-events: none;
        transform: scale(1.45);
      }

      .contact-columns {
        position: relative;
        z-index: 1;
        margin-top: 1rem;
        display: grid;
        grid-template-columns: 1fr 1px 1fr;
        gap: 0 clamp(1rem, 2.5vw, 3rem);
        align-items: start;
      }

      .contact-divider {
        background: rgba(0, 0, 0, 0.15);
        align-self: stretch;
      }

      .contact-col {
        display: flex;
        flex-direction: column;
        gap: clamp(0.85rem, 1.5vw, 1rem);
      }

      .contact-section-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(1rem, 1.4vw, 1.2rem);
        color: #0e3947;
        margin: 0 0 0.4rem;
        line-height: 1.1;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .contact-name {
        font-family: "Superglue", sans-serif;
        font-size: clamp(1.4rem, 2.3vw, 2.5rem);
        color: #111;
        margin: 0;
        line-height: 1.1;
      }

      .contact-subtitle {
        font-size: clamp(0.78rem, 1vw, 1rem);
        color: #333;
        line-height: 1.6;
        margin: 0;
        border-left: 3px solid #0099cc;
        padding-left: 0.75rem;
        font-family: "Overload Burn";
      }

      .contact-rule {
        border: none;
        border-top: 1px solid rgba(0,0,0,0.12);
        margin: 0.1rem 0;
        display: block !important;
      }

      .contact-col p.body {
        margin: 0;
        font-size: clamp(0.96rem, 1.2vw, 1rem);
        line-height: 1.8;
        color: #222;
        font-family: "JAVATEXT";
      }

      .contact-link-item {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        border-left: 2px solid rgba(0, 153, 204, 0.35);
        padding-left: 0.75rem;
        font-family: "JAVATEXT";
      }

      .contact-link-item strong {
        font-size: clamp(1rem, 1vw, 1.05rem);
        color: #111;
        font-family: "Overload Burn";
      }

      .contact-link-item a {
        font-size: clamp(0.95rem, 1vw, 1rem);
        color: #0099cc;
        text-decoration: none;
        word-break: break-all;
      }

      .contact-link-item a:hover {
        text-decoration: underline;
      }

      .contact-link-item span {
        font-size: clamp(0.85rem, 1vw, 0.95rem);
        color: #333;
        line-height: 1.5;
        font-family: "JAVATEXT";
      }

      footer {
        position: relative;
        z-index: 2;
      }

      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      /* Mobile section boxes — inert on desktop: acts as a transparent flex passthrough */
      .mob-section {
        position: static;
        padding: 0;
        margin: 0;
        overflow: visible;
        display: flex;
        flex-direction: column;
        gap: clamp(0.85rem, 1.5vw, 1rem);
      }
      .mob-section-bg {
        display: none;
      }

      @media (max-width: 1024px) {
        .contact-wrap {
          width: min(920px, 90vw);
          padding: clamp(3.5rem, 8vw, 5rem) 1rem clamp(4rem, 8vw, 6rem);
          transform: translateX(0.5rem);
        }
      }

      /* ══════════════════════════════════════
         MOBILE ONLY — max-width: 768px
         Desktop styles above are untouched
      ══════════════════════════════════════ */
      @media (max-width: 768px) {
        /* Allow scrolling */
        html, body,
        .page-transition-content,
        main {
          overflow-y: auto !important;
          height: auto !important;
          max-height: none !important;
        }

        /* Hide divider lines between sections on mobile */
        .contact-rule { display: none !important; }

        /* Desktop video off, contact-page no longer needs to host any video */
        .contact-video-bg.desktop { display: none; }

        /* The real fixed background — a direct child of <body>, isolated from
           every other element's positioning/stacking/transform context, so it
           can't be dragged along by anything and can't end up covering the
           footer's stacking order. Negative z-index keeps it behind literally
           everything without needing to "win" a z-index comparison. */
        .mobile-bg-video {
          display: block;
          position: fixed;
          inset: 0;
          width: 100%;
          height: 100%;
          object-fit: cover;
          z-index: -1;
          pointer-events: none;
        }

        /* Page: grow to fit content, background lives outside it now */
        .contact-page {
          min-height: 100svh;
          overflow: visible;
          position: relative;
        }

        /* Title: in-flow */
        .page-title {
          font-size: clamp(1.4rem, 10vw, 4rem);
          position: relative;
          top: auto;
          left: -2rem;
          padding: 0.55rem 1rem 0;
          display: block;
        }

        /* Wrap */
        .contact-wrap {
          width: min(92vw, 680px);
          padding-top: 0.75rem;
          padding-bottom: 3rem;
          transform: translateX(0);
        }

        /* Main animbox: hide its own bg on mobile — each section gets its own */
        .contact-animbox {
          padding: 0;
          margin-top: 4rem;
          display: block;
          background: none;
        }

        .contact-animbox-bg {
          display: none;
        }

        /* Columns: stack vertically */
        .contact-columns {
          display: flex;
          flex-direction: column;
          gap: 5rem;
          margin-top: 0;
        }

        /* Hide desktop divider */
        .contact-divider { display: none; }

        /* Column inner gap */
        .contact-col { gap: 4rem; }

        /* ── Per-section animated box ── */
        .mob-section {
          display: block;
          position: relative;
          padding: 2rem 3rem 2rem 4.5rem;
          overflow: visible;
          margin-bottom: 3rem;
        }

        /* First mob-section gets top clip so bg doesn't bleed into title */
        .contact-col:first-child .mob-section:first-child {
          padding-top: 3rem;
          padding-bottom: 3rem;
          clip-path: inset(0 -50% -50% -50%);
        }

        .mob-section-bg {
          display: block;
          position: absolute;
          top: 50%;
          left: 50%;
          width: 175%;
          height: 170%;
          object-fit: fill;
          z-index: 0;
          pointer-events: none;
          transform: translate(-50%, -50%);
          transform-origin: center;
        }

        /* First box gets a bit more canvas */
        .contact-col:first-child .mob-section:first-child .mob-section-bg {
          width: 185%;
          height: 180%;
        }

        /* All direct children sit above the bg */
        .mob-section > *:not(.mob-section-bg) {
          position: relative;
          z-index: 1;
        }

        /* Typography scaling */
        .contact-name {
          font-size: clamp(1.1rem, 4.8vw, 1.5rem);
          line-height: 1.15;
        }

        .contact-subtitle {
          font-size: clamp(0.78rem, 3.2vw, 0.95rem);
        }

        .contact-section-title {
          font-size: 1rem;
          letter-spacing: 0.08em;
        }

        .contact-col p.body {
          font-size: clamp(0.85rem, 3.2vw, 1rem);
          line-height: 1.7;
        }

        .contact-link-item strong {
          font-size: clamp(0.85rem, 3.2vw, 0.95rem);
        }

        .contact-link-item a,
        .contact-link-item span {
          font-size: clamp(0.8rem, 3vw, 0.9rem);
        }
      }
    </style>
  </head>
  <body>
    <!-- Mobile fixed background: lives here, outside Header/main/Footer,
         so it has zero entanglement with their layout, transforms, or
         stacking contexts. Only visible/active in the mobile media query. -->
    <video class="mobile-bg-video" autoplay muted loop playsinline preload="metadata">
      <source src="/contactmobile.webm" type="video/webm" />
    </video>

    <Header />
    <main>
      <div class="page-transition-content">
        <div class="contact-page">
          <video class="contact-video-bg desktop" autoplay muted loop playsinline preload="metadata">
            <source src="/contactani.webm" type="video/webm" />
          </video>

          <div class="contact-wrap">
            <h1 class="page-title">CONTACT</h1>

            <div class="contact-animbox">
              <img class="contact-animbox-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />

              <div class="contact-columns">

                <!-- LEFT COLUMN -->
                <div class="contact-col">

                  <!-- SECTION: Identity + Intro -->
                  <div class="mob-section">
                    <img class="mob-section-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
                    <h2 class="contact-name">Get In<br/>Touch</h2>
                    <p class="contact-subtitle">
                      Jacob Gordillo<br/>
                      Designer &amp; Editorial Illustrator<br/>
                      Indianapolis, Indiana
                    </p>
                    <hr class="contact-rule" />
                    <p class="contact-section-title">Let's Work Together</p>
                    <p class="body">
                      I'm currently available for freelance work, commissions, or full-time positions.
                      Whether you need editorial illustration, branding, political advertising, or concept
                      art, I'd love to hear from you and I'm excited to put my passion behind a project I believe in!
                    </p>
                    <p class="body">
                      I'm also open to opportunities involving campaign work and political communication.
                      If you think my skills could be a good fit for your team or project, don't hesitate
                      to reach out!
                    </p>
                  </div>

                  <hr class="contact-rule" />
                </div>

                <!-- DIVIDER -->
                <div class="contact-divider"></div>

                <!-- RIGHT COLUMN -->
                <div class="contact-col" style="padding-top: 1rem;">

                  <!-- SECTION: Contact Info -->
                  <div class="mob-section">
                    <img class="mob-section-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
                    <p class="contact-section-title">Contact</p>

                    <div class="contact-link-item">
                      <strong>Email</strong>
                      <a href="mailto:Jacobfgordillo@gmail.com">Jacobfgordillo@gmail.com</a>
                    </div>

                    <div class="contact-link-item">
                      <strong>Phone</strong>
                      <span>812-361-3942</span>
                    </div>

                    <div class="contact-link-item">
                      <strong>Location</strong>
                      <span>Indianapolis, Indiana</span>
                    </div>

                    <div class="contact-link-item">
                      <strong>Portfolio</strong>
                      <a href="/portfolio">art-jacobg.com/portfolio</a>
                    </div>
                  </div>

                  <hr class="contact-rule" />

                  <!-- SECTION: Availability -->
                  <div class="mob-section">
                    <img class="mob-section-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
                    <p class="contact-section-title">Availability</p>

                    <div class="contact-link-item">
                      <strong>Freelance &amp; Commissions</strong>
                      <span>Open — reach out any time</span>
                    </div>

                    <div class="contact-link-item">
                      <strong>Full-time / Contract</strong>
                      <span>Available — design, illustration, campaign work</span>
                    </div>

                    <div class="contact-link-item">
                      <strong>Response Time</strong>
                      <span>Usually within 24–48 hours</span>
                    </div>
                  </div>

                </div>

              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>