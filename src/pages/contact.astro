---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
  title="Contact"
  description="Get in touch"
  pubDate={new Date('2026-02-18')}
>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    padding: 0 !important;
    overflow-x: hidden;
    background: #4ad9e6;
  }

  main {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .title { display: none; }
  .date { display: none; }
  hr { display: none; }

  .contact-video-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    object-fit: cover;
    object-position: center center;
    z-index: -1;
    pointer-events: none;
  }

  .contact-page {
    position: relative;
    min-height: 100vh;
    width: 100%;
    z-index: 1;
  }

  .contact-wrap {
    width: min(1050px, 72vw);
    margin: 0 auto;
    padding-top: 80px;
    padding-bottom: 150px;
  }

  .contact-page-title {
    font-family: "Superglue", sans-serif;
    font-size: clamp(40px, 5.2vw, 82px);
    line-height: 0.9;
    color: white;
    margin: 0 0 60px 0;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    text-shadow: 0 0 50px rgba(0,0,0,0.35);
  }

  .contact-animbox {
    position: relative;
    width: 100%;
    display: grid;
    padding: clamp(1.5rem, 3vw, 3rem);
    overflow: visible;
  }

  .contact-animbox-bg {
    position: absolute;
    inset: -8% -12%;
    width: 124%;
    height: 116%;
    object-fit: fill;
    z-index: 0;
    pointer-events: none;
  }

  .contact-columns {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 0 3rem;
    align-items: start;
  }

  .contact-divider {
    background: rgba(0, 0, 0, 0.15);
    align-self: stretch;
  }

  .contact-col {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .contact-section-title {
    font-family: "Superglue", sans-serif;
    font-size: 1rem;
    color: #0e3947;
    margin: 0;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .contact-name {
    font-family: "Superglue", sans-serif;
    font-size: clamp(1.2rem, 2vw, 2rem);
    color: #111;
    margin: 0;
    line-height: 1.1;
  }

  .contact-subtitle {
    font-size: clamp(0.65rem, 0.9vw, 0.8rem);
    color: #333;
    line-height: 1.6;
    margin: 0;
    border-left: 3px solid #111;
    padding-left: 0.75rem;
    font-family: "Overload Burn";
  }

  .contact-rule {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.12);
    margin: 0.1rem 0;
    display: block !important;
  }

  .contact-col p.body {
    margin: 0;
    font-size: clamp(0.68rem, 0.85vw, 0.82rem);
    line-height: 1.75;
    color: #222;
    font-family: "Overload Burn";
  }

  .contact-link-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    border-left: 2px solid rgba(0,0,0,0.25);
    padding-left: 0.75rem;
    font-family: "JAVATEXT";
  }

  .contact-link-item strong {
    font-size: clamp(0.75rem, 0.82vw, 0.9rem);
    color: #111;
    font-family: "Overload Burn";
  }

  .contact-link-item a {
    font-size: clamp(0.65rem, 0.78vw, 0.85rem);
    color: #0099cc;
    text-decoration: none;
    word-break: break-all;
  }

  .contact-link-item a:hover {
    text-decoration: underline;
  }

  .contact-link-item span {
    font-size: clamp(0.65rem, 0.78vw, 0.82rem);
    color: #333;
    line-height: 1.5;
    font-family: "Overload Burn";
  }

  footer {
    position: relative;
    z-index: 2;
  }

  @media (max-width: 768px) {
    .contact-wrap { width: 92vw; padding-top: 60px; }
    .contact-columns { grid-template-columns: 1fr; gap: 2rem; }
    .contact-divider { display: none; }
  }
</style>

<video class="contact-video-bg" autoplay muted loop playsinline>
  <source src="/contactani.webm" type="video/webm" />
</video>

<div class="contact-page">
  <div class="contact-wrap">

    <h1 class="contact-page-title">CONTACT</h1>

    <div class="contact-animbox">
      <img class="contact-animbox-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />

      <div class="contact-columns">

        <!-- LEFT -->
        <div class="contact-col">
          <h2 class="contact-name">Get In<br/>Touch</h2>

          <p class="contact-subtitle">
            Jacob Gordillo<br/>
            Designer &amp; Editorial Illustrator<br/>
            Indianapolis, Indiana
          </p>

          <hr class="contact-rule" />
          <p class="contact-section-title">Let's Work Together</p>

          <p class="body">
            I'm currently available for freelance work, commissions, or full-time positions.
            Whether you need editorial illustration, branding, political advertising, or concept
            art, I'd love to hear from you and I'm excited to put my passion behind a project I beleive in!
          </p>
          <p class="body">
            I'm also open to opportunities involving campaign work and political communication.
            If you think my skills could be a good fit for your team or project, don't hesitate
            to reach out!
          </p>

          <hr class="contact-rule" />
        </div>

        <!-- DIVIDER -->
        <div class="contact-divider"></div>

        <!-- RIGHT -->
        <div class="contact-col" style="padding-top: 1rem;">
          <p class="contact-section-title">Contact</p>

          <div class="contact-link-item">
            <strong>Email</strong>
            <a href="mailto:Jacobfgordillo@gmail.com">Jacobfgordillo@gmail.com</a>
          </div>

          <div class="contact-link-item">
            <strong>Phone</strong>
            <span>812-361-3942</span>
          </div>

          <div class="contact-link-item">
            <strong>Location</strong>
            <span>Indianapolis, Indiana</span>
          </div>

          <div class="contact-link-item">
            <strong>Portfolio</strong>
            <a href="/portfolio">art-jacobg.com/portfolio</a>
          </div>

          <hr class="contact-rule" />
          <p class="contact-section-title">Availability</p>

          <div class="contact-link-item">
            <strong>Freelance &amp; Commissions</strong>
            <span>Open — reach out any time</span>
          </div>

          <div class="contact-link-item">
            <strong>Full-time / Contract</strong>
            <span>Available — design, illustration, campaign work</span>
          </div>

          <div class="contact-link-item">
            <strong>Response Time</strong>
            <span>Usually within 24–48 hours</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

</Layout>