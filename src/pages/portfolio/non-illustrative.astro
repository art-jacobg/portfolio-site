---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const nonIllustrativeWorks = Array.from({ length: 8 }, (_, i) => i);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Non-Illustrative Works | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        overflow-x: hidden;
        background: #f4f4f4;
      }

      .hero-container {
        position: relative;
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
      }

      .hero-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        z-index: 0;
      }

      .content-wrapper {
        position: relative;
        z-index: 2;
        width: min(1450px, 94vw);
        margin: 0 auto;
        padding-top: 10rem;
        padding-bottom: 6rem;
      }

      /* =========================
         TITLE
      ========================== */

      .title-block {
        margin-bottom: 4rem;
      }

      .page-title {
        font-family: "Superglue";
        font-size: clamp(4rem, 9vw, 8rem);
        line-height: 0.85;
        color: white;
        margin: 0;
        max-width: 1000px;
        text-transform: uppercase;
        letter-spacing: -0.05em;

        text-shadow:
          0 0 25px rgba(255,255,255,0.1),
          0 0 60px rgba(0,0,0,0.25);
      }

      /* =========================
         INTRO BOX
      ========================== */

      .intro-animbox {
        position: relative;
        width: 100%;
        min-height: 380px;

        margin-bottom: 5rem;

        border-radius: 14px;
        overflow: hidden;

        display: flex;
        align-items: center;

        padding:
          clamp(2.5rem, 5vw, 5rem)
          clamp(2.5rem, 6vw, 6rem);

        box-shadow:
          0 25px 70px rgba(0,0,0,0.22),
          inset 0 0 0 1px rgba(255,255,255,0.08);
      }

      .intro-animbox-bg {
        position: absolute;

        top: 50%;
        left: 50%;

        width: 135%;
        height: 135%;

        transform:
          translate(-50%, -50%)
          scaleX(1.25);

        object-fit: fill;

        z-index: 0;

        opacity: 0.96;

        pointer-events: none;
      }

      .intro-overlay {
        position: absolute;
        inset: 0;

        background:
          linear-gradient(
            90deg,
            rgba(255,255,255,0.92) 0%,
            rgba(255,255,255,0.86) 45%,
            rgba(255,255,255,0.80) 100%
          );

        z-index: 1;
      }

      .intro-inner {
        position: relative;
        z-index: 2;

        width: 100%;

        display: grid;
        grid-template-columns: 1fr 1px 1.1fr;
        gap: 4rem;
        align-items: center;
      }

      .intro-divider {
        width: 1px;
        height: 100%;
        background: rgba(0,0,0,0.15);
      }

      .intro-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .intro-kicker {
        font-family: "Superglue";
        font-size: 0.75rem;
        color: #00b7ff;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 1rem;
      }

      .intro-title {
        font-family: "Superglue";
        font-size: clamp(2.7rem, 5vw, 5rem);
        line-height: 0.88;
        margin: 0 0 1.5rem 0;
        color: #111;
        text-transform: uppercase;
      }

      .intro-subtitle {
        margin: 0;

        font-size: clamp(0.95rem, 1vw, 1.08rem);
        line-height: 1.9;
        color: #222;

        border-left: 4px solid #00bfff;
        padding-left: 1rem;

        max-width: 500px;
      }

      .intro-right {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .section-label {
        font-family: "Superglue";
        font-size: 0.75rem;
        letter-spacing: 0.14em;
        color: #008bb8;
        text-transform: uppercase;
        margin-bottom: 1rem;
      }

      .intro-right p:last-child {
        margin: 0;

        color: #1d1d1d;
        line-height: 2;
        font-size: clamp(0.95rem, 1vw, 1.05rem);
      }

      /* =========================
         WORKS GRID
      ========================== */

      .works-section {
        position: relative;
        z-index: 2;
      }

      .works-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
      }

      .works-title {
        font-family: "Superglue";
        font-size: clamp(1.7rem, 3vw, 2.8rem);
        color: white;
        margin: 0;
        text-transform: uppercase;
      }

      .works-count {
        color: rgba(255,255,255,0.8);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .works-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 2rem;
      }

      .work-item {
        position: relative;
        aspect-ratio: 3 / 4;

        border-radius: 14px;
        overflow: hidden;

        cursor: pointer;

        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
      }

      .work-item:hover {
        transform: translateY(-10px) scale(1.02);

        box-shadow:
          0 25px 50px rgba(0,0,0,0.35),
          0 0 0 1px rgba(255,255,255,0.15);
      }

      .work-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .work-overlay {
        position: absolute;
        inset: 0;

        display: flex;
        align-items: flex-end;

        padding: 1.25rem;

        background:
          linear-gradient(
            to top,
            rgba(0,0,0,0.72) 0%,
            rgba(0,0,0,0.15) 45%,
            transparent 70%
          );
      }

      .work-title {
        font-family: "Superglue";
        color: white;
        font-size: 1rem;
        text-transform: uppercase;
      }

      /* =========================
         MODAL
      ========================== */

      .modal {
        position: fixed;
        inset: 0;

        display: flex;
        align-items: center;
        justify-content: center;

        background: rgba(0,0,0,0.88);

        z-index: 9999;

        opacity: 0;
        pointer-events: none;

        transition: opacity 0.3s ease;
      }

      .modal.active {
        opacity: 1;
        pointer-events: auto;
      }

      .modal-card {
        width: min(520px, 90vw);
        height: min(900px, 88vh);

        perspective: 1600px;

        transform: scale(0.92);
        transition: transform 0.35s ease;
      }

      .modal.active .modal-card {
        transform: scale(1);
      }

      .modal-inner {
        width: 100%;
        height: 100%;

        position: relative;

        transform-style: preserve-3d;
        transition: transform 0.8s ease;
      }

      .modal-card:hover .modal-inner {
        transform: rotateY(180deg);
      }

      .modal-front,
      .modal-back {
        position: absolute;
        inset: 0;

        backface-visibility: hidden;
      }

      .modal-back {
        transform: rotateY(180deg);
      }

      .modal-front img,
      .modal-back img {
        width: 100%;
        height: 100%;
        object-fit: contain;

        background: white;

        border-radius: 12px;

        box-shadow:
          0 0 80px rgba(0,0,0,0.75);
      }

      /* =========================
         MOBILE
      ========================== */

      @media (max-width: 900px) {
        .content-wrapper {
          padding-top: 8rem;
        }

        .page-title {
          font-size: clamp(3rem, 14vw, 5.5rem);
        }

        .intro-inner {
          grid-template-columns: 1fr;
          gap: 2rem;
        }

        .intro-divider {
          display: none;
        }

        .intro-animbox {
          min-height: auto;
          padding: 2rem;
        }

        .works-grid {
          grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
          gap: 1rem;
        }

        .works-header {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.5rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main class="hero-container">

      <img
        class="hero-image"
        src="/portfolio banner 2.webp"
        alt="Portfolio banner"
      />

      <div class="content-wrapper">

        <!-- TITLE -->

        <section class="title-block">
          <h1 class="page-title">
            NON-ILLUSTRATIVE<br />
            WORKS
          </h1>
        </section>

        <!-- INTRO -->

        <section class="intro-animbox">

          <img
            class="intro-animbox-bg"
            src="/box animation slow1.webp"
            alt=""
            aria-hidden="true"
          />

          <div class="intro-overlay"></div>

          <div class="intro-inner">

            <div class="intro-left">

              <div class="intro-kicker">
                Design Collection
              </div>

              <h2 class="intro-title">
                Non-Illustrative<br />
                Works
              </h2>

              <p class="intro-subtitle">
                Branding systems, motion concepts,
                layout-driven projects, and visual
                communication work beyond illustration.
              </p>

            </div>

            <div class="intro-divider"></div>

            <div class="intro-right">

              <div class="section-label">
                About This Collection
              </div>

              <p>
                This collection focuses on structure,
                communication, motion, typography,
                branding, and experimental layout systems.
                These projects explore how visual identity
                and composition can create meaning across
                digital and physical formats.
              </p>

            </div>

          </div>

        </section>

        <!-- WORK GRID -->

        <section class="works-section">

          <div class="works-header">

            <h2 class="works-title">
              Project Gallery
            </h2>

            <div class="works-count">
              08 Selected Works
            </div>

          </div>

          <div class="works-grid">

            {nonIllustrativeWorks.map((i) => (
              <div
                class="work-item"
                data-front={`/portfolio/non-illustrative/${i}.webp`}
                data-back={`/portfolio/non-illustrative/${i} back.webp`}
              >

                <img
                  src={`/portfolio/non-illustrative/${i}.webp`}
                  alt={`Non-illustrative work ${i + 1}`}
                  loading="lazy"
                />

                <div class="work-overlay">
                  <div class="work-title">
                    Work {i + 1}
                  </div>
                </div>

              </div>
            ))}

          </div>

        </section>

      </div>

    </main>

    <!-- MODAL -->

    <div id="modal" class="modal">

      <div class="modal-card">

        <div class="modal-inner">

          <div class="modal-front">
            <img id="modalFront" src="" alt="" />
          </div>

          <div class="modal-back">
            <img id="modalBack" src="" alt="" />
          </div>

        </div>

      </div>

    </div>

    <script>
      const modal = document.getElementById('modal');
      const modalFront = document.getElementById('modalFront');
      const modalBack = document.getElementById('modalBack');

      document.querySelectorAll('.work-item').forEach((item) => {
        item.addEventListener('click', () => {
          modalFront.src = item.dataset.front;
          modalBack.src = item.dataset.back || '';

          modal.classList.add('active');
        });
      });

      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.remove('active');

          setTimeout(() => {
            modalFront.src = '';
            modalBack.src = '';
          }, 300);
        }
      });
    </script>

    <Footer />

  </body>
</html>