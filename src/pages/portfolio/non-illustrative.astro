---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Non-Illustrative Works | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { font-size: 16px; }

      body {
        margin: 0;
        padding: 0 !important;
        background: #f5f5f5;
        font-size: 16px;
        overflow-x: hidden;
      }

      main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
        overflow-x: hidden;
      }

      /* ── HERO ── */
      .ilw-hero {
        position: relative;
        width: 100%;
        min-height: 100%;
        background: #fff;
      }

      /* ── VIDEO BACKGROUND ── */
      .ilw-bg-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center center;
        z-index: 0;
        pointer-events: none;
      }

      /* ── CONTENT SHELL ── */
      .ilw-wrap {
        position: relative;
        z-index: 2;
        width: min(1050px, 90vw);
        margin: 0 auto;
        padding: clamp(4rem, 8vw, 7rem) 1rem clamp(4.5rem, 10vw, 8rem);
      }

      /* ── PAGE TITLE ── */
      .ilw-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(3rem, 5.2vw, 82px);
        line-height: 0.9;
        color: white;
        margin: 0 0 clamp(3rem, 4vw, 6rem) 0;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        text-shadow: 0 0 50px rgba(0,0,0,0.35);
      }

      /* ── INTRO BOX ── */
      .ilw-intro {
        position: relative;
        width: min(680px, 100%);
        margin: 0 auto clamp(2rem, 4vw, 3.5rem) auto;
        border-radius: 18px;
        overflow: visible;
        padding: clamp(2rem, 4vw, 3.5rem);
        box-shadow: 0 28px 80px rgba(0,0,0,0.28);
      }

      .ilw-intro-bg {
        position: absolute;
        top: 50%; left: 50%;
        width: 100%; height: 100%;
        transform: translate(-50%, -50%) scale(1.7);
        object-fit: fill;
        z-index: 0;
        opacity: 0.96;
        pointer-events: none;
      }

      .ilw-intro-inner {
        position: relative;
        z-index: 2;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .ilw-intro-top { display: flex; flex-direction: column; }

      .ilw-intro-kicker {
        font-family: "Superglue", sans-serif;
        font-size: 11px;
        color: #00b7ff;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin: 0 0 12px 0;
      }

      .ilw-intro-heading {
        font-family: "Superglue", sans-serif;
        font-size: clamp(22px, 2.8vw, 38px);
        line-height: 0.88;
        color: #111;
        text-transform: uppercase;
        margin: 0 0 20px 0;
      }

      .ilw-intro-sub {
        margin: 0;
        font-size: clamp(0.85rem, 1vw, 1rem);
        line-height: 1.85;
        color: #333;
        border-left: 4px solid #00bfff;
        padding-left: clamp(0.85rem, 1vw, 1.1rem);
      }

      .ilw-intro-divider {
        width: 100%;
        height: 1px;
        background: rgba(0,0,0,0.12);
      }

      .ilw-intro-bottom { display: flex; flex-direction: column; gap: 10px; }

      .ilw-intro-label {
        font-family: "Superglue", sans-serif;
        font-size: clamp(0.75rem, 1vw, 0.95rem);
        letter-spacing: 0.14em;
        color: #008bb8;
        text-transform: uppercase;
        margin: 0;
      }

      .ilw-intro-body {
        margin: 0;
        font-size: clamp(0.95rem, 1vw, 1rem);
        line-height: 1.9;
        color: #1d1d1d;
      }

      /* ── MEDIA COLUMN ── */
      .media-column {
        display: flex;
        flex-direction: column;
        gap: clamp(1.5rem, 3vw, 2.5rem);
        margin-top: clamp(3rem, 6vw, 5rem);
        width: 100%;
      }

      /* Each row: gif on left, video on right */
      .media-row {
        display: grid;
        grid-template-columns: 1fr 1.6fr;
        gap: clamp(1.5rem, 3vw, 2.5rem);
        align-items: center;
      }

      /* ── GIF / PLACEHOLDER shared sizing ── */
      .media-gif,
      .media-placeholder {
        width: 100%;
        border-radius: 14px;
        display: block;
      }

      .media-gif {
      }

      /* invisible placeholder — same dimensions as the gif slot */
      .media-placeholder {
        aspect-ratio: 1 / 1; /* adjust if you know the gif's exact ratio */
        background: transparent;
        pointer-events: none;
      }

      /* ── VIDEO EMBED ── */
      .media-embed {
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
      }

      .media-embed iframe {
        width: 100%;
        height: 100%;
        border: none;
        display: block;
      }

      /* invisible embed placeholder */
      .media-embed-placeholder {
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 14px;
        background: transparent;
        pointer-events: none;
      }

      /* ── TABLET ── */
      @media (max-width: 1024px) {
        .ilw-wrap { padding-top: 60px; }
        .ilw-intro { width: 100%; padding: 28px 24px; }
        .media-row { grid-template-columns: 1fr; }
      }

      @media (max-width: 768px) {
        .ilw-wrap { padding: 40px 1rem; }
        .ilw-title { font-size: clamp(2.8rem, 10vw, 4.5rem); }
        .ilw-intro { padding: 24px 18px; }
      }

      @media (max-width: 480px) {
        .ilw-wrap { padding: 30px 0.75rem; }
        .ilw-title { font-size: clamp(2.4rem, 12vw, 4rem); }
        .ilw-intro { padding: 20px 16px; }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <div class="ilw-hero">

        <video class="ilw-bg-video" autoplay muted loop playsinline preload="metadata">
          <source src="/portfoliobannerani.webm" type="video/webm" />
        </video>

        <div class="ilw-wrap">

          <h1 class="ilw-title">NON-ILLUSTRATIVE<br />WORKS</h1>

          <!-- INTRO BOX -->
          <div class="ilw-intro">
            <img class="ilw-intro-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
            <div class="ilw-intro-inner">
              <div class="ilw-intro-top">
                <p class="ilw-intro-kicker">Design Collection</p>
                <h2 class="ilw-intro-heading">Beyond<br />Illustration</h2>
                <p class="ilw-intro-sub">
                  Branding systems, motion concepts, layout-driven projects, and visual communication work beyond illustration.
                </p>
              </div>
              <div class="ilw-intro-divider"></div>
              <div class="ilw-intro-bottom">
                <p class="ilw-intro-label">About This Collection</p>
                <p class="ilw-intro-body">
                  This collection focuses on structure, communication, motion, typography, branding, and experimental layout systems. These projects explore how visual identity and composition can create meaning across digital and physical formats.
                </p>
              </div>
            </div>
          </div>

          <!-- MEDIA COLUMN -->
          <div class="media-column">

            <!-- ROW 1: Wizard Juice gif + YouTube embed -->
            <div class="media-row">
              <img
                class="media-gif"
                src="/wizardjuice.gif"
                alt="Wizard Juice animation"
              />
              <div class="media-embed">
                <iframe
                  src="https://www.youtube.com/embed/jTkYjbenrzo?si=tuZyY7iSfbkIBztg"
                  title="YouTube video player"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
            </div>

            <!-- ROW 2: placeholder gif slot + placeholder embed slot -->
            <div class="media-row">
              <div class="media-placeholder"></div>
              <div class="media-embed-placeholder"></div>
            </div>

            <!-- ROW 3: placeholder gif slot + placeholder embed slot -->
            <div class="media-row">
              <div class="media-placeholder"></div>
              <div class="media-embed-placeholder"></div>
            </div>

            <!-- ROW 4: placeholder gif slot + placeholder embed slot -->
            <div class="media-row">
              <div class="media-placeholder"></div>
              <div class="media-embed-placeholder"></div>
            </div>

          </div>

        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>