---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const nonIllustrativeWorks = Array.from({ length: 8 }, (_, i) => i);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Non-Illustrative Works | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { font-size: 16px; }

      body {
        margin: 0;
        padding: 0 !important;
        overflow-x: hidden;
        background: #f5f5f5;
        font-size: 16px;
      }

      main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      /* ── HERO ── */
      .hero {
        position: relative;
        width: 100%;
        min-height: 100%;
        overflow: hidden;
        background: #f4f4f4;
      }

      /* ── IMAGE BACKGROUND ── */
      .hero-bg-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        z-index: 0;
        pointer-events: none;
      }

      /* ── CONTENT SHELL ── */
      .wrap {
        position: relative;
        z-index: 2;
        width: min(1050px, 78vw);
        margin: 0 auto;
        padding-top: 100px;
        padding-bottom: 100px;
      }

      /* ── PAGE TITLE ── */
      .page-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(40px, 5.2vw, 82px);
        line-height: 0.9;
        color: white;
        margin: 0 0 110px 0;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        text-shadow: 0 0 50px rgba(0,0,0,0.35);
      }

      /* ── INTRO BOX ── */
      .intro {
        position: relative;
        width: 72%;
        margin: 0 auto 50px auto;
        border-radius: 18px;
        overflow: visible;
        padding: 56px 64px;
        box-shadow: 0 28px 80px rgba(0,0,0,0.28);
      }

      .intro-bg {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 100%;
        height: 100%;
        transform: translate(-50%, -50%) scale(1.7);
        object-fit: fill;
        z-index: 0;
        opacity: 0.96;
        pointer-events: none;
      }

      .intro-inner {
        position: relative;
        z-index: 2;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .intro-top { display: flex; flex-direction: column; }

      .intro-kicker {
        font-family: "Superglue", sans-serif;
        font-size: 11px;
        color: #00b7ff;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin: 0 0 12px 0;
      }

      .intro-heading {
        font-family: "Superglue", sans-serif;
        font-size: clamp(22px, 2.8vw, 38px);
        line-height: 0.88;
        color: #111;
        text-transform: uppercase;
        margin: 0 0 20px 0;
      }

      .intro-sub {
        margin: 0;
        font-size: 14px;
        line-height: 1.85;
        color: #333;
        border-left: 4px solid #00bfff;
        padding-left: 14px;
        max-width: 520px;
      }

      .intro-divider {
        width: 100%;
        height: 1px;
        background: rgba(0,0,0,0.12);
      }

      .intro-bottom { display: flex; flex-direction: column; gap: 10px; }

      .intro-label {
        font-family: "Superglue", sans-serif;
        font-size: 11px;
        letter-spacing: 0.14em;
        color: #008bb8;
        text-transform: uppercase;
        margin: 0;
      }

      .intro-body {
        margin: 0;
        font-size: 13px;
        line-height: 1.9;
        color: #1d1d1d;
        max-width: 680px;
      }

      /* ── WORKS HEADER ── */
      .works-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 100px;
        margin-bottom: 28px;
      }

      .works-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(24px, 3vw, 44px);
        color: white;
        text-transform: uppercase;
        margin: 0;
      }

      .works-count {
        color: rgba(255,255,255,0.8);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      /* ── GRID ── */
      .works-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
      }

      .work-item {
        position: relative;
        aspect-ratio: 3 / 4;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.3s, box-shadow 0.3s;
      }

      .work-item:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 24px 48px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.15);
      }

      .work-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .work-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: flex-end;
        padding: 16px;
        background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 45%, transparent 70%);
      }

      .work-label {
        font-family: "Superglue", sans-serif;
        color: white;
        font-size: 13px;
        text-transform: uppercase;
      }

      /* ── MODAL ── */
      .modal {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.88);
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s;
      }

      .modal.active {
        opacity: 1;
        pointer-events: auto;
      }

      .modal-card {
        width: min(520px, 90vw);
        height: min(900px, 88vh);
        perspective: 1600px;
        transform: scale(0.92);
        transition: transform 0.35s ease;
      }

      .modal.active .modal-card {
        transform: scale(1);
      }

      .modal-inner {
        width: 100%;
        height: 100%;
        position: relative;
        transform-style: preserve-3d;
        transition: transform 0.8s ease;
      }

      .modal-card:hover .modal-inner {
        transform: rotateY(180deg);
      }

      .modal-front,
      .modal-back {
        position: absolute;
        inset: 0;
        backface-visibility: hidden;
      }

      .modal-back { transform: rotateY(180deg); }

      .modal-front img,
      .modal-back img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        background: white;
        border-radius: 12px;
        box-shadow: 0 0 80px rgba(0,0,0,0.75);
      }

      /* ── MOBILE ── */
      @media (max-width: 900px) {
        .wrap { padding-top: 60px; }
        .intro, .works-header { width: 100%; }
        .intro { padding: 28px 24px; width: 100%; }
        .works-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
        .modal-card { width: 92vw; }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <div class="hero">

        <!-- BACKGROUND IMAGE -->
        <img
          class="hero-bg-img"
          src="/portfolio banner 2.webp"
          alt=""
          aria-hidden="true"
        />

        <div class="wrap">

          <!-- TITLE -->
          <h1 class="page-title">NON-ILLUSTRATIVE<br />WORKS</h1>

          <!-- INTRO BOX -->
          <div class="intro">
            <img class="intro-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
            <div class="intro-inner">
              <div class="intro-top">
                <p class="intro-kicker">Design Collection</p>
                <h2 class="intro-heading">Non-Illustrative<br />Works</h2>
                <p class="intro-sub">
                  Branding systems, motion concepts,
                  layout-driven projects, and visual
                  communication work beyond illustration.
                </p>
              </div>
              <div class="intro-divider"></div>
              <div class="intro-bottom">
                <p class="intro-label">About This Collection</p>
                <p class="intro-body">
                  This collection focuses on structure,
                  communication, motion, typography,
                  branding, and experimental layout systems.
                  These projects explore how visual identity
                  and composition can create meaning across
                  digital and physical formats.
                </p>
              </div>
            </div>
          </div>

          <!-- WORKS GRID -->
          <div class="works-header">
            <h2 class="works-title">Project Gallery</h2>
            <div class="works-count">08 Selected Works</div>
          </div>

          <div class="works-grid">
            {nonIllustrativeWorks.map((i) => (
              <div
                class="work-item"
                data-front={`/portfolio/non-illustrative/${i}.webp`}
                data-back={`/portfolio/non-illustrative/${i} back.webp`}
              >
                <img
                  src={`/portfolio/non-illustrative/${i}.webp`}
                  alt={`Non-illustrative work ${i + 1}`}
                  loading="lazy"
                />
                <div class="work-overlay">
                  <span class="work-label">Work {i + 1}</span>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </main>

    <!-- MODAL -->
    <div id="modal" class="modal">
      <div class="modal-card">
        <div class="modal-inner">
          <div class="modal-front">
            <img id="modalFront" src="" alt="" />
          </div>
          <div class="modal-back">
            <img id="modalBack" src="" alt="" />
          </div>
        </div>
      </div>
    </div>

    <script>
      const modal = document.getElementById('modal');
      const modalFront = document.getElementById('modalFront');
      const modalBack = document.getElementById('modalBack');

      document.querySelectorAll('.work-item').forEach((item) => {
        item.addEventListener('click', () => {
          modalFront.src = item.dataset.front;
          modalBack.src = item.dataset.back || '';
          modal.classList.add('active');
        });
      });

      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.remove('active');
          setTimeout(() => {
            modalFront.src = '';
            modalBack.src = '';
          }, 300);
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') modal.classList.remove('active');
      });
    </script>

    <Footer />
  </body>
</html>