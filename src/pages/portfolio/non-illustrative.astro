---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const nonIllustrativeWorks = Array.from({ length: 8 }, (_, i) => i); // Adjust number as needed
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Non-Illustrative Works | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />

    <style>
      body { margin: 0; font-family: 'JAVATEXT', sans-serif; }

      /* Hero */
      .hero-container {
        position: relative;
        width: 100%;
        min-height: 150vh;
        overflow: visible; /* allow modal outside */
      }

      .hero-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 1;
        filter: brightness(0.7) contrast(1.1) saturate(1.2) hue-rotate(210deg);
      }

      .page-title {
        font-family: "JAVATEXT";
        font-size: 6.5rem;
        color: white;
        position: absolute;
        top: 2rem;
        left: 2rem;
        z-index: 20;
        margin: 0;
      }

      .work-description {
        position: absolute;
        left: 2.7rem;
        max-width: 1700px;
        color: white;
        font-size: 1.4rem;
        line-height: 1.5;
        z-index: 20;
      }

      .work-description:first-of-type { top: 9rem; }
      .work-description:last-of-type { top: 17rem; }

      /* Works Grid */
      .works-grid {
        position: relative;
        z-index: 10;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        justify-items: center;
        gap: 3rem;
        padding-top: 23rem;
        padding-bottom: 10rem;
        max-width: 1400px;
        margin: auto;
      }

      .work-item {
        width: 300px;
        height: 500px;
        cursor: pointer;
        transition: transform 0.2s ease;
      }

      .work-item:hover { transform: scale(1.07); }
      .work-item:active { transform: scale(0.95); } /* shrink when clicked */

      .work-item img {
        width: 100%;
        height: 100%;
        object-fit: contain; /* do not crop */
        border-radius: 16px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.45);
        background: white;
      }

      /* Modal */
      .modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.85);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s ease;
      }

      .modal.active {
        opacity: 1;
        pointer-events: auto;
      }

      .modal-card {
        width: 500px;
        height: 875px;
        perspective: 1400px;
        transform: scale(0.9);
        transition: transform 0.4s ease;
      }

      .modal.active .modal-card { transform: scale(1); }

      .modal-inner {
        width: 100%;
        height: 100%;
        position: relative;
        transition: transform 0.7s;
        transform-style: preserve-3d;
      }

      .modal-card:hover .modal-inner { transform: rotateY(180deg); }

      .modal-front,
      .modal-back {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
      }

      .modal-front img,
      .modal-back img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 10px;
        box-shadow: 0 0 80px rgba(0,0,0,0.8);
        background: white;
      }

      .modal-back { transform: rotateY(180deg); }
    </style>
  </head>

  <body>
    <Header />

    <div class="hero-container">
      <img class="hero-image" src="/portfolio banner.webp" alt="Portfolio Banner" />

      <!-- Descriptions -->
      <p class="work-description">Design systems, branding, motion concepts, and layout-driven work that focuses on visual communication beyond illustration.</p>
      <p class="work-description">These projects showcase my expertise in design thinking and problem-solving.</p>

      <!-- Works Grid -->
      <div class="works-grid">
        {nonIllustrativeWorks.map((i) => (
          <div 
            class="work-item"
            data-front={`/portfolio/non-illustrative/${i}.webp`}
            data-back={`/portfolio/non-illustrative/${i} back.webp`}
          >
            <img src={`/portfolio/non-illustrative/${i}.webp`} alt={`Non-illustrative work ${i}`} />
          </div>
        ))}
      </div>
    </div>

    <!-- Modal -->
    <div id="modal" class="modal">
      <div class="modal-card">
        <div class="modal-inner">
          <div class="modal-front">
            <img id="modalFront" src="" />
          </div>
          <div class="modal-back">
            <img id="modalBack" src="" />
          </div>
        </div>
      </div>
    </div>

    <script>
      const modal = document.getElementById("modal");
      const modalFront = document.getElementById("modalFront");
      const modalBack = document.getElementById("modalBack");
      const items = document.querySelectorAll(".work-item");

      items.forEach(item => {
        item.addEventListener("click", () => {
          modalFront.src = item.getAttribute("data-front");
          modalBack.src = item.getAttribute("data-back");
          modal.classList.add("active");
        });
      });

      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.classList.remove("active");
          setTimeout(() => {
            modalFront.src = "";
            modalBack.src = "";
          }, 300);
        }
      });
    </script>

    <Footer />
  </body>
</html>