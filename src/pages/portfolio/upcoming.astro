---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const upcomingProjects = Array.from({ length: 5 }, (_, i) => i);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Upcoming Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />

    <style>
      *, *::before, *::after { box-sizing: border-box; }

      html { font-size: 16px; }

      body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        background: #f5f5f5;
      }

      main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      /* ─────────────────────────────
         HERO (MATCHES ILLUSTRATIVE)
      ───────────────────────────── */

      .ilw-hero {
        position: relative;
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
      }

      /* VIDEO BACKGROUND (THIS IS THE KEY FIX) */
      .ilw-bg-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        z-index: 0;
        pointer-events: none;
      }

      /* CONTENT WRAP */
      .wrap {
  position: relative;
  z-index: 2;
  width: min(1050px, 78vw);
  margin: 0 auto;
  padding-top: 100px;
  padding-bottom: 100px;
}

      /* TITLE */
      .page-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(40px, 5.2vw, 82px);
        line-height: 0.9;
        color: white;
        margin: 0 0 110px 0;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        text-shadow: 0 0 50px rgba(0,0,0,0.35);
      }

      /* INTRO BOX */
     .intro {
  position: relative;
  width: 72%;
  margin: 0 auto 50px auto;
  border-radius: 18px;
  padding: 56px 64px;
  box-shadow: 0 28px 80px rgba(0,0,0,0.28);
}

      .intro-inner {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .intro-kicker {
        font-family: "Superglue", sans-serif;
        font-size: 11px;
        color: #00b7ff;
        text-transform: uppercase;
        letter-spacing: 0.15em;
      }

      .intro-heading {
        font-family: "Superglue", sans-serif;
        font-size: clamp(22px, 2.8vw, 38px);
        line-height: 0.88;
        color: #111;
        text-transform: uppercase;
      }

      .intro-sub {
        font-size: 14px;
        line-height: 1.85;
        color: #333;
        border-left: 4px solid #00bfff;
        padding-left: 14px;
        max-width: 520px;
      }
.intro-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  transform: translate(-50%, -50%) scale(1.7);
  object-fit: fill;
  z-index: 0;
  opacity: 0.96;
  pointer-events: none;
}
      /* HEADER */
      .works-header {
        display: flex;
        justify-content: space-between;
        margin-top: 100px;
        margin-bottom: 28px;
      }

      .works-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(24px, 3vw, 44px);
        color: white;
        text-transform: uppercase;
      }

      .works-count {
        color: rgba(255,255,255,0.8);
        font-size: 0.9rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      /* GRID */
      .works-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
      

      .work-item {
        position: relative;
        aspect-ratio: 3 / 4;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(6px);
        transition: transform 0.3s;
      }

      .work-item:hover {
        transform: translateY(-8px) scale(1.02);
      }

      .work-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .work-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: flex-end;
        padding: 16px;
        background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
      }

      .work-label {
        font-family: "Superglue", sans-serif;
        color: white;
        font-size: 13px;
        text-transform: uppercase;
      }

      /* MODAL */
      .modal {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.88);
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s;
      }

      .modal.active {
        opacity: 1;
        pointer-events: auto;
      }

      .modal-card {
        width: min(520px, 90vw);
        height: min(900px, 88vh);
      }

     @media (max-width: 900px) {
  .wrap { padding-top: 60px; }

  .intro {
    width: 100%;
    padding: 28px 24px;
  }

  .works-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
}
    </style>
  </head>

  <body>
    <Header />

    <main>

      <!-- FIXED: NOW USING WORKING ANIMATED BACKGROUND -->
      <div class="ilw-hero">

        <video class="ilw-bg-video" autoplay muted loop playsinline>
          <source src="/portfoliobannerani.webm" type="video/webm" />
        </video>

        <div class="wrap">

          <h1 class="page-title">UPCOMING<br />PROJECTS</h1>

         <div class="intro">
  <!-- THIS IS THE MISSING “central animation box slow” BACKGROUND -->
  <img
    class="intro-bg"
    src="/box animation slow3.webp"
    alt=""
    aria-hidden="true"
  />

  <div class="intro-inner">
    <p class="intro-kicker">In Development</p>
    <h2 class="intro-heading">Future Works</h2>
    <p class="intro-sub">
      Sneak peeks at projects currently in progress and upcoming creative directions.ks at projects currently in progress and upcoming creative directions.
    </p>
  </div>
</div>
          <div class="works-header">
            <h2 class="works-title">Preview Gallery</h2>
            <div class="works-count">05 Upcoming Releases</div>
          </div>

          <div class="works-grid">
            {upcomingProjects.map((i) => (
              <div class="work-item">
                <img src="/box animation slow1.webp" alt="" />
                <div class="work-overlay">
                  <span class="work-label">Upcoming Project {i + 1}</span>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>

    </main>

    <Footer />
  </body>
</html>