---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Upcoming Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />

    <style>
      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        font-size: 16px;
        overflow-x: hidden;
      }

      body {
        padding: 0 !important;
      }

      main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
        overflow-x: hidden;
      }

      /* ── HERO ── */
      .ilw-hero {
        position: relative;
        width: 100%;
        height: auto;
        overflow: clip;
      }

      /* ── VIDEO BACKGROUND ── */
      .ilw-bg-video {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        object-fit: cover;
        object-position: center center;
        z-index: 0;
        pointer-events: none;
      }

      /* ── CONTENT SHELL ── */
      .ilw-wrap {
        position: relative;
        z-index: 2;
        width: min(1050px, 90vw);
        margin: 0 auto;
        padding: clamp(3rem, 6vw, 5rem) 1rem clamp(3rem, 6vw, 5rem);
      }

      /* ── PAGE TITLE ── */
      .ilw-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(2rem, 3.8vw, 58px);
        line-height: 0.9;
        color: white;
        margin: 0 0 clamp(1.25rem, 2vw, 2.5rem) 0;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        text-shadow: 0 0 50px rgba(0,0,0,0.35);
      }

      /* ── PAGE SWITCHER DROPDOWN ── */
      .ilw-page-switcher {
        position: relative;
        width: fit-content;
        margin: 0 0 clamp(1rem, 2vw, 1.5rem) 0;
        z-index: 5;
      }

      .ilw-page-switch-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "Superglue", sans-serif;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: 1.5px solid rgba(255,255,255,0.3);
        padding: 7px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(10px);
        color: white;
        cursor: pointer;
        transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
      }

      .ilw-page-switch-btn:hover {
        background: rgba(255,255,255,0.22);
      }

      .ilw-page-switch-caret {
        font-size: 9px;
        line-height: 1;
        transition: transform 0.2s;
        font-style: normal;
      }

      .ilw-page-switcher.open .ilw-page-switch-btn {
        background: #00bfff;
        box-shadow: 0 0 24px rgba(0,191,255,0.5);
      }

      .ilw-page-switcher.open .ilw-page-switch-caret {
        transform: rotate(180deg);
      }

      .ilw-page-switch-menu {
        position: absolute;
        top: calc(100% + 10px);
        left: 0;
        transform: translateY(-8px);
        list-style: none;
        margin: 0;
        padding: 8px;
        min-width: 220px;
        border-radius: 14px;
        background: rgba(15,15,18,0.92);
        backdrop-filter: blur(14px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.4);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s, transform 0.2s;
        z-index: 20;
      }

      .ilw-page-switcher.open .ilw-page-switch-menu {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      .ilw-page-switch-menu li {
        font-family: "Superglue", sans-serif;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255,255,255,0.85);
        padding: 10px 14px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        list-style: none;
      }

      .ilw-page-switch-menu li:hover {
        background: rgba(255,255,255,0.12);
        color: white;
      }

      .ilw-page-switch-menu li.active {
        background: #00bfff;
        color: white;
      }

      /* ── INTRO BOX ── */
      .ilw-intro {
        position: relative;
        width: min(580px, 100%);
        margin: 0 auto clamp(1.25rem, 2.5vw, 2.5rem) auto;
        border-radius: 18px;
        overflow: visible;
        padding: clamp(1.25rem, 2.5vw, 2.5rem);
        box-shadow: 0 28px 80px rgba(0,0,0,0.28);
      }

      .ilw-intro-bg {
        position: absolute;
        top: 50%; left: 50%;
        width: 80%; height: 110%;
        transform: translate(-50%, -50%) scale(1.7);
        object-fit: fill;
        z-index: 0;
        opacity: 0.96;
        pointer-events: none;
        border-radius: 18px;
      }

      .ilw-intro-inner {
        position: relative;
        z-index: 2;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .ilw-intro-top { display: flex; flex-direction: column; }

      .ilw-intro-kicker {
        font-family: "Superglue", sans-serif;
        font-size: 11px;
        color: #00b7ff;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin: 0 0 12px 0;
      }

      .ilw-intro-heading {
        font-family: "Superglue", sans-serif;
        font-size: clamp(22px, 2.8vw, 38px);
        line-height: 0.88;
        color: #111;
        text-transform: uppercase;
        margin: 0 0 20px 0;
      }

      .ilw-intro-sub {
        margin: 0;
        font-size: clamp(0.85rem, 1vw, 1rem);
        line-height: 1.85;
        color: #333;
        border-left: 4px solid #00bfff;
        padding-left: clamp(0.85rem, 1vw, 1.1rem);
      }

      .ilw-intro-divider {
        width: 100%;
        height: 1px;
        background: rgba(0,0,0,0.12);
      }

      .ilw-intro-bottom { display: flex; flex-direction: column; gap: 10px; }

      .ilw-intro-label {
        font-family: "Superglue", sans-serif;
        font-size: clamp(0.75rem, 1vw, 0.95rem);
        letter-spacing: 0.14em;
        color: #008bb8;
        text-transform: uppercase;
        margin: 0;
      }

      .ilw-intro-body {
        margin: 0;
        font-size: clamp(0.95rem, 1vw, 1rem);
        line-height: 1.9;
        color: #1d1d1d;
      }

      /* ── SECTION HEADER ── */
      .works-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: clamp(1rem, 2vw, 2rem);
        margin-top: clamp(5rem, 8vw, 9rem);
        margin-bottom: clamp(1rem, 2vw, 1.5rem);
      }

      .works-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(24px, 3vw, 44px);
        color: white;
        text-transform: uppercase;
        margin: 0;
      }

      .works-count {
        color: rgba(255,255,255,0.8);
        font-size: 0.9rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      /* ── PROJECT CARD ── */
      .project-card {
        position: relative;
        border-radius: 18px;
        overflow: visible;
        padding: clamp(1rem, 2vw, 1.75rem);
        padding-bottom: clamp(2rem, 3vw, 2.5rem);
        width: 100%;
      }

      .project-card-bg {
        position: absolute;
        top: 50%; left: 50%;
        width: 80%; height: 110%;
        transform: translate(-50%, -50%) scale(1.7);
        object-fit: fill;
        z-index: 0;
        opacity: 0.96;
        pointer-events: none;
        border-radius: 18px;
      }

      .project-card-inner {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: minmax(0, 300px) 1fr;
        gap: clamp(1rem, 2vw, 1.75rem);
        align-items: center;
      }

      /* ── IMAGE SIDE ── */
      .project-img-clip {
        width: 100%;
        border-radius: 10px;
        overflow: hidden;
        position: relative;
        z-index: 2;
        margin-top: 50px;
      }

      .project-img {
        width: 100%;
        height: auto;
        display: block;
        cursor: pointer;
        transition: transform 0.25s, box-shadow 0.25s;
      }

      .project-img:hover {
        transform: scale(1.02);
      }

      .project-img-wrap {
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-width: 0;
      }

      .project-img-hint {
        font-family: "Superglue", sans-serif;
        font-size: 9px;
        color: rgba(0,0,0,0.4);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        text-align: center;
        margin: 0;
      }

      /* ── TEXT SIDE ── */
      .project-info {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .project-kicker {
        font-family: "Superglue", sans-serif;
        font-size: 11px;
        color: #00b7ff;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin: 0;
      }

      .project-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(20px, 2.5vw, 34px);
        line-height: 0.9;
        color: #111;
        text-transform: uppercase;
        margin: 0;
      }

      .project-divider {
        width: 100%;
        height: 1px;
        background: rgba(0,0,0,0.12);
      }

      .project-body {
        margin: 0;
        font-size: clamp(0.85rem, 1vw, 1rem);
        line-height: 1.85;
        color: #333;
        border-left: 4px solid #00bfff;
        padding-left: clamp(0.85rem, 1vw, 1.1rem);
      }

      .project-label {
        font-family: "Superglue", sans-serif;
        font-size: clamp(0.75rem, 1vw, 0.95rem);
        letter-spacing: 0.14em;
        color: #008bb8;
        text-transform: uppercase;
        margin: 0;
      }

      .project-note {
        margin: 0;
        font-size: clamp(0.85rem, 1vw, 0.95rem);
        line-height: 1.9;
        color: #1d1d1d;
      }

      /* ── LIGHTBOX ── */
      .lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.92);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s;
        overflow: hidden;
      }

      .lightbox.active {
        opacity: 1;
        pointer-events: auto;
      }

      .lightbox img {
        max-width: 90vw;
        max-height: 90vh;
        width: auto;
        height: auto;
        border-radius: 10px;
        box-shadow: 0 0 80px rgba(0,0,0,0.75);
        transform-origin: center center;
        transform: translate(0,0) scale(1);
        transition: transform 0.15s ease;
        cursor: default;
        user-select: none;
        -webkit-user-drag: none;
      }

      .lightbox-hint {
        position: fixed;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        font-family: "Superglue", sans-serif;
        font-size: 10px;
        color: rgba(255,255,255,0.45);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s;
      }

      .lightbox.active .lightbox-hint {
        opacity: 1;
      }

      .lightbox-close {
        position: absolute;
        top: 18px;
        right: 18px;
        background: rgba(255,255,255,0.15);
        border: none;
        color: white;
        font-size: 16px;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        transition: background 0.2s, transform 0.2s;
        z-index: 10001;
      }

      .lightbox-close:hover {
        background: rgba(255,255,255,0.3);
        transform: scale(1.1);
      }

      .project-img.clicking {
        transform: scale(1.07);
        transition: transform 0.1s ease !important;
        box-shadow: 0 0 0 2px rgba(255,255,255,0.4), 0 24px 48px rgba(0,0,0,0.4);
      }

      /* ── TABLET ── */
      @media (max-width: 1024px) {
        .ilw-wrap { padding-top: 60px; }

        .ilw-intro {
          width: 100%;
          padding: 28px 24px;
        }

        .project-card-inner {
          grid-template-columns: 1fr;
        }

        .works-header {
          flex-direction: column;
          align-items: flex-start;
        }
      }

      /* ── MOBILE ── */
      @media (max-width: 768px) {

        html, body,
        .page-transition-content,
        main {
          overflow-y: auto !important;
          height: auto !important;
          max-height: none !important;
        }

        .ilw-hero {
          height: auto;
          overflow: clip;
        }

        .ilw-wrap {
          padding: 72px 1rem 40px;
        }

        /* hide title on mobile — dropdown takes its place */
        .ilw-title {
          display: none;
        }

        /* dropdown acts as the page title on mobile — bigger + more breathing room */
        .ilw-page-switcher {
          margin: 0 0 2.5rem 0;
        }

        .ilw-page-switch-btn {
          font-size: 1.25rem;
          padding: 10px 18px;
          gap: 10px;
        }

        .ilw-page-switch-caret {
          font-size: 11px;
        }

        .ilw-intro {
          width: 100%;
          margin-left: auto;
          margin-right: auto;
          padding: 24px 18px;
          overflow: visible;
          clip-path: inset(-20px -100vw -100vw -100vw);
          box-shadow: 0 28px 80px rgba(0,0,0,0.35);
        }

        .ilw-intro-bg {
          width: 80%;
          height: 110%;
          transform: translate(-50%, -50%) scale(1.7);
          border-radius: 18px;
        }

        .works-header {
          flex-direction: column;
          align-items: flex-start;
          margin-top: clamp(5rem, 12vw, 7rem);
          margin-bottom: 0.75rem;
        }

        .works-title {
          font-size: clamp(20px, 6vw, 32px);
        }

        .project-card-inner {
          grid-template-columns: 1fr;
          align-items: start;
          gap: 12px;
        }

        .project-img-clip {
          margin-top: 0;
          max-height: 42vw;
          overflow: hidden;
        }

        .project-img-hint {
          font-size: 8px;
          margin-top: 4px;
        }

        .project-info {
          gap: 10px;
        }

        .project-kicker {
          font-size: 9px;
        }

        .project-title {
          font-size: clamp(16px, 5vw, 22px);
          line-height: 1;
        }

        .project-body {
          font-size: 0.78rem;
          line-height: 1.6;
        }

        .project-label {
          font-size: 0.7rem;
        }

        .project-note {
          font-size: 0.78rem;
          line-height: 1.6;
        }

        .project-card {
          padding: 14px 14px 20px 14px;
        }

        .project-card-bg {
          top: 45%;
          width: 80%;
        }
      }

      @media (max-width: 480px) {
        .ilw-wrap {
          padding: 28px 0.75rem;
        }

        .ilw-intro {
          padding: 20px 16px;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <div class="ilw-hero">

        <video class="ilw-bg-video" autoplay muted loop playsinline preload="metadata">
          <source src="/portfoliobannerani.webm" type="video/webm" />
        </video>

        <div class="ilw-wrap">

          <!-- PAGE SWITCHER DROPDOWN -->
          <div class="ilw-page-switcher">
            <button id="ilwPageSwitchBtn" class="ilw-page-switch-btn" aria-haspopup="listbox" aria-expanded="false">
              <span id="ilwPageSwitchLabel">Upcoming Projects</span>
              <span class="ilw-page-switch-caret">▼</span>
            </button>
            <ul id="ilwPageSwitchMenu" class="ilw-page-switch-menu" role="listbox">
              <li role="option" data-href="/portfolio/illustrative">Illustrative</li>
              <li role="option" data-href="/portfolio/non-illustrative">Non-Illustrative</li>
              <li role="option" data-href="/tarot">Tarot</li>
              <li role="option" data-href="/portfolio/upcoming" class="active">Upcoming</li>
            </ul>
          </div>

          <h1 class="ilw-title">UPCOMING<br />PROJECTS</h1>

          <!-- INTRO BOX -->
          <div class="ilw-intro">
            <img class="ilw-intro-bg" src="/box%20animation%20slow3.webp" alt="" aria-hidden="true" />
            <div class="ilw-intro-inner">
              <div class="ilw-intro-top">
                <p class="ilw-intro-kicker">In Development</p>
                <h2 class="ilw-intro-heading">Future Works</h2>
                <p class="ilw-intro-sub">
                  Sneak peeks at projects currently in progress.
                </p>
              </div>
              <div class="ilw-intro-divider"></div>
              <div class="ilw-intro-bottom">
                <p class="ilw-intro-label">About This Collection</p>
                <p class="ilw-intro-body">
                  Updates and previews on my solo or group projects.
                </p>
              </div>
            </div>
          </div>

          <!-- SECTION HEADER -->
          <div class="works-header">
            <h2 class="works-title">Preview Gallery</h2>
          </div>

          <!-- PROJECT CARD -->
          <div class="project-card">
            <img class="project-card-bg" src="/box%20animation%20slow1.webp" alt="" aria-hidden="true" />
            <div class="project-card-inner">

              <!-- IMAGE SIDE -->
              <div class="project-img-wrap">
                <div class="project-img-clip">
                  <img
                    class="project-img"
                    src="/portfolio/upcoming/swordcomps.webp"
                    alt="Sword Compositions — Future Terraria Mod"
                    id="swordImg"
                  />
                </div>
                <p class="project-img-hint">↑ Click to enlarge</p>
              </div>

              <!-- TEXT SIDE -->
              <div class="project-info">
                <p class="project-kicker">In Development</p>
                <h3 class="project-title">Future Terraria Mod: Project Nadir</h3>
                <div class="project-divider"></div>
                <p class="project-body">
                  Collaberative effort between me and 2 other talented artists and developers. This mod will add the Sun Sword Nadir as a fully animated boss encounter with custom assets, animations and music. Can you tame it?
                </p>
                <p class="project-label">Status</p>
                <p class="project-note">
                  Currently in early development. More details coming soon.
                </p>
              </div>

            </div>
          </div>

        </div>
      </div>
    </main>

    <!-- LIGHTBOX -->
    <div class="lightbox" id="lightbox">
      <button class="lightbox-close" id="lightboxClose" aria-label="Close">&#x2715;</button>
      <img src="/portfolio/upcoming/swordcomps.webp" alt="Sword Compositions — Future Terraria Mod" />
      <p class="lightbox-hint">Scroll to zoom · Drag to pan · Double-click to reset · Click outside to close</p>
    </div>

    <script>
      const img = document.getElementById('swordImg') as HTMLImageElement;
      const lightbox = document.getElementById('lightbox') as HTMLElement;
      const lbImg = lightbox.querySelector('img') as HTMLImageElement;
      const closeBtn = document.getElementById('lightboxClose') as HTMLButtonElement;

      let scale = 1;
      let originX = 0;
      let originY = 0;
      let isDragging = false;
      let startX: number = 0;
      let startY: number = 0;
      let lastTouchDist: number | null = null;

      function applyTransform(): void {
        lbImg.style.transform = `translate(${originX}px, ${originY}px) scale(${scale})`;
      }

      function resetZoom(): void {
        scale = 1;
        originX = 0;
        originY = 0;
        applyTransform();
      }

      function openLightbox(): void {
        resetZoom();
        lightbox.classList.add('active');
      }

      function closeLightbox(): void {
        lightbox.classList.remove('active');
        resetZoom();
      }

      img.addEventListener('click', () => {
        img.classList.add('clicking');
        setTimeout(() => {
          img.classList.remove('clicking');
          openLightbox();
        }, 120);
      });

      closeBtn.addEventListener('click', closeLightbox);

      lightbox.addEventListener('click', (e: MouseEvent) => {
        if (e.target === lightbox) closeLightbox();
      });

      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') closeLightbox();
      });

      lightbox.addEventListener('wheel', (e: WheelEvent) => {
        e.preventDefault();
        const delta = e.deltaY > 0 ? -0.15 : 0.15;
        scale = Math.min(Math.max(scale + delta, 1), 6);
        if (scale === 1) { originX = 0; originY = 0; }
        applyTransform();
      }, { passive: false });

      lbImg.addEventListener('mousedown', (e: MouseEvent) => {
        if (scale <= 1) return;
        isDragging = true;
        startX = e.clientX - originX;
        startY = e.clientY - originY;
        lbImg.style.cursor = 'grabbing';
        e.preventDefault();
      });

      document.addEventListener('mousemove', (e: MouseEvent) => {
        if (!isDragging) return;
        originX = e.clientX - startX;
        originY = e.clientY - startY;
        applyTransform();
      });

      document.addEventListener('mouseup', () => {
        isDragging = false;
        lbImg.style.cursor = scale > 1 ? 'grab' : 'default';
      });

      lbImg.addEventListener('dblclick', () => {
        resetZoom();
      });

      lightbox.addEventListener('wheel', () => {
        lbImg.style.cursor = scale > 1 ? 'grab' : 'default';
      });

      lightbox.addEventListener('touchstart', (e: TouchEvent) => {
        if (e.touches.length === 2) {
          lastTouchDist = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
          );
        }
      }, { passive: true });

      lightbox.addEventListener('touchmove', (e: TouchEvent) => {
        if (e.touches.length === 2) {
          const dist = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
          );
          if (lastTouchDist !== null) {
            const delta = (dist - lastTouchDist) * 0.01;
            scale = Math.min(Math.max(scale + delta, 1), 6);
            if (scale === 1) { originX = 0; originY = 0; }
            applyTransform();
          }
          lastTouchDist = dist;
        }
      }, { passive: true });

      lightbox.addEventListener('touchend', () => {
        lastTouchDist = null;
      });
    </script>

    <!-- PAGE SWITCHER SCRIPT -->
    <script>
      const pageSwitcher   = document.querySelector('.ilw-page-switcher') as HTMLElement;
      const pageSwitchBtn  = document.getElementById('ilwPageSwitchBtn') as HTMLButtonElement;
      const pageSwitchMenu = document.getElementById('ilwPageSwitchMenu') as HTMLElement;

      function closePageSwitcher(): void {
        pageSwitcher.classList.remove('open');
        pageSwitchBtn.setAttribute('aria-expanded', 'false');
      }

      pageSwitchBtn.addEventListener('click', (e: MouseEvent) => {
        e.stopPropagation();
        const isOpen = pageSwitcher.classList.toggle('open');
        pageSwitchBtn.setAttribute('aria-expanded', String(isOpen));
      });

      pageSwitchMenu.querySelectorAll<HTMLElement>('li').forEach(li => {
        li.addEventListener('click', () => {
          const href = li.dataset.href;
          if (href) window.location.href = href;
        });
      });

      document.addEventListener('click', (e: MouseEvent) => {
        if (!pageSwitcher.contains(e.target as Node)) closePageSwitcher();
      });

      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') closePageSwitcher();
      });
    </script>

    <Footer />
  </body>
</html>