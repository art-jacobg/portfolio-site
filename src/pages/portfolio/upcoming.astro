---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const upcomingProjects = Array.from({ length: 5 }, (_, i) => i);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Upcoming Projects | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        overflow-x: hidden;
        background: #f5f5f5;
      }

      .hero-container {
        position: relative;
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
      }

      .hero-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        z-index: 0;
      }

      .hero-overlay {
        position: relative;
        z-index: 2;
        width: min(1450px, 94vw);
        margin: 0 auto;
        padding-top: 11rem;
        padding-bottom: 6rem;
      }

      /* =========================
         TITLE
      ========================== */

      .title-block {
        margin-bottom: 5rem;
      }

      .page-title {
        font-family: "Superglue";
        font-size: clamp(4rem, 10vw, 9rem);
        line-height: 0.85;
        color: white;
        margin: 0;
        text-transform: uppercase;
        max-width: 850px;
        letter-spacing: -0.04em;
        text-shadow:
          0 0 10px rgba(255,255,255,0.1),
          0 0 30px rgba(0,0,0,0.25);
      }

      /* =========================
         INFO BOX
      ========================== */

      .intro-animbox {
        position: relative;
        width: 100%;
        min-height: 360px;
        border-radius: 12px;
        overflow: hidden;
        padding: clamp(3rem, 5vw, 5rem);
        margin-bottom: 5rem;

        display: flex;
        align-items: center;

        box-shadow:
          0 20px 60px rgba(0,0,0,0.22),
          inset 0 0 0 1px rgba(255,255,255,0.15);
      }

      .intro-animbox-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        opacity: 0.95;
      }

      .intro-darken {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(
            90deg,
            rgba(255,255,255,0.94) 0%,
            rgba(255,255,255,0.88) 50%,
            rgba(255,255,255,0.82) 100%
          );
        z-index: 1;
      }

      .intro-inner {
        position: relative;
        z-index: 2;

        width: 100%;

        display: grid;
        grid-template-columns: 1.1fr 1px 1fr;
        gap: 4rem;
        align-items: center;
      }

      .intro-divider {
        width: 1px;
        height: 100%;
        background: rgba(0,0,0,0.15);
      }

      .intro-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .section-tag {
        font-family: "Superglue";
        font-size: 0.8rem;
        color: #00aee6;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }

      .intro-title {
        font-family: "Superglue";
        font-size: clamp(2.8rem, 5vw, 5rem);
        line-height: 0.9;
        color: #111;
        margin: 0 0 1.5rem 0;
        text-transform: uppercase;
      }

      .intro-subtitle {
        font-size: clamp(0.95rem, 1.1vw, 1.1rem);
        line-height: 1.8;
        color: #222;
        max-width: 520px;

        border-left: 4px solid #00bfff;
        padding-left: 1rem;
      }

      .intro-right {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .intro-right-label {
        font-family: "Superglue";
        font-size: 0.75rem;
        color: #0086b3;
        margin-bottom: 1rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .intro-right p {
        margin: 0;
        color: #1b1b1b;
        line-height: 2;
        font-size: clamp(0.95rem, 1vw, 1.05rem);
      }

      /* =========================
         PROJECT GRID
      ========================== */

      .works-section {
        position: relative;
        z-index: 2;
      }

      .works-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
      }

      .works-title {
        font-family: "Superglue";
        font-size: clamp(1.5rem, 3vw, 2.8rem);
        color: white;
        margin: 0;
        text-transform: uppercase;
      }

      .works-count {
        color: rgba(255,255,255,0.8);
        font-size: 0.9rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .works-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 2rem;
      }

      .work-item {
        position: relative;
        aspect-ratio: 3 / 4;
        border-radius: 14px;
        overflow: hidden;
        cursor: pointer;

        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(6px);

        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
      }

      .work-item:hover {
        transform: translateY(-10px) scale(1.02);

        box-shadow:
          0 20px 40px rgba(0,0,0,0.35),
          0 0 0 1px rgba(255,255,255,0.15);
      }

      .work-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .work-overlay {
        position: absolute;
        inset: 0;

        background:
          linear-gradient(
            to top,
            rgba(0,0,0,0.7) 0%,
            rgba(0,0,0,0.15) 40%,
            transparent 70%
          );

        display: flex;
        align-items: flex-end;

        padding: 1.25rem;
      }

      .work-title {
        font-family: "Superglue";
        color: white;
        font-size: 1rem;
        line-height: 1.2;
        text-transform: uppercase;
      }

      /* =========================
         MODAL
      ========================== */

      .modal {
        position: fixed;
        inset: 0;
        z-index: 9999;

        display: flex;
        align-items: center;
        justify-content: center;

        background: rgba(0,0,0,0.88);

        opacity: 0;
        pointer-events: none;

        transition: opacity 0.35s ease;
      }

      .modal.active {
        opacity: 1;
        pointer-events: auto;
      }

      .modal-card {
        width: min(520px, 90vw);
        height: min(900px, 88vh);

        perspective: 1600px;

        transform: scale(0.92);
        transition: transform 0.35s ease;
      }

      .modal.active .modal-card {
        transform: scale(1);
      }

      .modal-inner {
        position: relative;
        width: 100%;
        height: 100%;

        transform-style: preserve-3d;
        transition: transform 0.8s ease;
      }

      .modal-card:hover .modal-inner {
        transform: rotateY(180deg);
      }

      .modal-front,
      .modal-back {
        position: absolute;
        inset: 0;

        backface-visibility: hidden;
      }

      .modal-back {
        transform: rotateY(180deg);
      }

      .modal-front img,
      .modal-back img {
        width: 100%;
        height: 100%;
        object-fit: contain;

        border-radius: 12px;

        background: white;

        box-shadow:
          0 0 80px rgba(0,0,0,0.7);
      }

      /* =========================
         MOBILE
      ========================== */

      @media (max-width: 900px) {
        .hero-overlay {
          padding-top: 8rem;
        }

        .page-title {
          font-size: clamp(3.5rem, 16vw, 6rem);
          max-width: 100%;
        }

        .intro-inner {
          grid-template-columns: 1fr;
          gap: 2rem;
        }

        .intro-divider {
          display: none;
        }

        .intro-animbox {
          min-height: auto;
          padding: 2rem;
        }

        .works-grid {
          grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
          gap: 1rem;
        }

        .works-header {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.5rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main class="hero-container">
      <img
        class="hero-image"
        src="/portfolio banner 2.webp"
        alt="Portfolio banner"
      />

      <div class="hero-overlay">

        <!-- TITLE -->
        <section class="title-block">
          <h1 class="page-title">
            UPCOMING<br />
            PROJECTS
          </h1>
        </section>

        <!-- INFO BOX -->
        <section class="intro-animbox">
          <img
            class="intro-animbox-bg"
            src="/box animation slow3.webp"
            alt=""
            aria-hidden="true"
          />

          <div class="intro-darken"></div>

          <div class="intro-inner">

            <div class="intro-left">
              <div class="section-tag">In Development</div>

              <h2 class="intro-title">
                Future<br />
                Works
              </h2>

              <div class="intro-subtitle">
                Sneak peeks at projects currently in progress,
                experimental concepts, and upcoming creative directions.
              </div>
            </div>

            <div class="intro-divider"></div>

            <div class="intro-right">
              <div class="intro-right-label">
                Coming Soon
              </div>

              <p>
                These projects represent the next stage of my
                creative practice — combining digital design,
                experimental visuals, branding systems, and
                new forms of interactive storytelling.
                More information and final releases will
                be revealed over time.
              </p>
            </div>

          </div>
        </section>

        <!-- PROJECT GRID -->
        <section class="works-section">

          <div class="works-header">
            <h2 class="works-title">
              Preview Gallery
            </h2>

            <div class="works-count">
              05 Upcoming Releases
            </div>
          </div>

          <div class="works-grid">
            {upcomingProjects.map((i) => (
              <div
                class="work-item"
                data-front={`/portfolio/upcoming/${i}.webp`}
                data-back={`/portfolio/upcoming/${i} back.webp`}
              >
                <img
  class="intro-animbox-bg"
  src="/box animation slow1.webp"
  alt=""
  aria-hidden="true"
/>

                <div class="work-overlay">
                  <div class="work-title">
                    Upcoming Project {i + 1}
                  </div>
                </div>
              </div>
            ))}
          </div>

        </section>

      </div>
    </main>

    <!-- MODAL -->

    <div id="modal" class="modal">
      <div class="modal-card">
        <div class="modal-inner">

          <div class="modal-front">
            <img id="modalFront" src="" alt="" />
          </div>

          <div class="modal-back">
            <img id="modalBack" src="" alt="" />
          </div>

        </div>
      </div>
    </div>

    <script>
      const modal = document.getElementById('modal');
      const modalFront = document.getElementById('modalFront');
      const modalBack = document.getElementById('modalBack');

      document.querySelectorAll('.work-item').forEach((item) => {
        item.addEventListener('click', () => {
          modalFront.src = item.dataset.front;
          modalBack.src = item.dataset.back || '';

          modal.classList.add('active');
        });
      });

      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.remove('active');

          setTimeout(() => {
            modalFront.src = '';
            modalBack.src = '';
          }, 300);
        }
      });
    </script>

    <Footer />
  </body>
</html>