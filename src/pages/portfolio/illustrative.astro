---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const illustrativeWorkGroups = [
  {
    id: 'concept-art',
    title: 'Concept Art',
    description: 'Here is a selection of some of my work!',
    works: [
      { src: '/portfolio/illustrative/concept art1.webp', alt: 'Concept art 1' },
      { src: '/portfolio/illustrative/concept art2.webp', alt: 'Concept art 2' },
      { src: '/portfolio/illustrative/concept art3.webp', alt: 'Concept art 3' },
      { src: '/portfolio/illustrative/concept art4.webp', alt: 'Concept art 4' },
      { src: '/portfolio/illustrative/concept art5.webp', alt: 'Concept art 5' },
      { src: '/portfolio/illustrative/concept art6.webp', alt: 'Concept art 6' },
      { src: '/portfolio/illustrative/concept art7.webp', alt: 'Concept art 7' },
      { src: '/portfolio/illustrative/concept art8.webp', alt: 'Concept art 8' },
      { src: '/portfolio/illustrative/concept art9.webp', alt: 'Concept art 9' },
      { src: '/portfolio/illustrative/conceptartmonster1.webp', alt: 'Concept art monster 1' },
      { src: '/portfolio/illustrative/conceptartmonster2.webp', alt: 'Concept art monster 2' },
      { src: '/portfolio/illustrative/conceptartmonster3.webp', alt: 'Concept art monster 3' },
      { src: '/portfolio/illustrative/item1.webp', alt: 'Item 1' },
      { src: '/portfolio/illustrative/item2.webp', alt: 'Item 2' },
      { src: '/portfolio/illustrative/item3.webp', alt: 'Item 3' },
      { src: '/portfolio/illustrative/item4.webp', alt: 'Item 4' },
      { src: '/portfolio/illustrative/item5.webp', alt: 'Item 5' },
      { src: '/portfolio/illustrative/item6.webp', alt: 'Item 6' },
      { src: '/portfolio/illustrative/item7.webp', alt: 'Item 7' },
      { src: '/portfolio/illustrative/item8.webp', alt: 'Item 8' },
      { src: '/portfolio/illustrative/item9.webp', alt: 'Item 9' },
      { src: '/portfolio/illustrative/item10.webp', alt: 'Item 10' },
      { src: '/portfolio/illustrative/item11.webp', alt: 'Item 11' },
      { src: '/portfolio/illustrative/item12.webp', alt: 'Item 12' },
      { src: '/portfolio/illustrative/item13.webp', alt: 'Item 13' },
      { src: '/portfolio/illustrative/item14.webp', alt: 'Item 14' },
    ],
  },
  {
    id: 'branding',
    title: 'Branding',
    description: 'Branding and visual identity work.',
    works: [
      { src: '/portfolio/illustrative/branding1.webp', alt: 'Branding 1' },
      { src: '/portfolio/illustrative/branding2.webp', alt: 'Branding 2' },
      { src: '/portfolio/illustrative/branding3.webp', alt: 'Branding 3' },
      { src: '/portfolio/illustrative/branding4.webp', alt: 'Branding 4' },
      { src: '/portfolio/illustrative/brandingmain.webp', alt: 'Branding main' },
    ],
  },
  {
    id: 'commissioned-works',
    title: 'Commissioned Works',
    description: 'Custom plush character designs and concepts.',
    works: [
      { src: '/portfolio/illustrative/portrait1.webp', alt: 'portrait1' },
      { src: '/portfolio/illustrative/portrait2.webp', alt: 'portrait2' },
      { src: '/portfolio/illustrative/sticker1.webp', alt: 'Commissioned Sticker' },
      { src: '/portfolio/illustrative/ales plushi.webp', alt: 'Ales plushie' },
      { src: '/portfolio/illustrative/eligos plushi.webp', alt: 'Eligos plushie' },
      { src: '/portfolio/illustrative/fen plushi.webp', alt: 'Fen plushie' },
      { src: '/portfolio/illustrative/gwydion plushi.webp', alt: 'Gwydion plushie' },
      { src: '/portfolio/illustrative/lucy plushi.webp', alt: 'Lucy plushie' },
      { src: '/portfolio/illustrative/pen plushi.webp', alt: 'Pen plushie' },
      { src: '/portfolio/illustrative/vi plushi.webp', alt: 'Vi plushie' },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Illustrative Works | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { font-size: 16px; }

      body {
        margin: 0;
        padding: 0 !important;
        font-size: 16px;
      }

      main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
        overflow-x: hidden;
      }

      /* ── HERO ── */
      .ilw-hero {
        position: relative;
        width: 100%;
        min-height: 100%;
      }

      /* ── VIDEO BACKGROUND ── */
      .ilw-bg-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center center;
        z-index: 0;
        pointer-events: none;
      }

      /* ── CONTENT SHELL ── */
      .ilw-wrap {
        position: relative;
        z-index: 2;
        width: min(1050px, 90vw);
        margin: 0 auto;
        padding: clamp(4rem, 8vw, 7rem) 1rem clamp(4.5rem, 10vw, 8rem);
      }

      /* ── PAGE TITLE ── */
      .ilw-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(3rem, 5.2vw, 82px);
        line-height: 0.9;
        color: white;
        margin: 0 0 clamp(3rem, 4vw, 6rem) 0;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        text-shadow: 0 0 50px rgba(0,0,0,0.35);
      }

      /* ── PAGE SWITCHER DROPDOWN ── */
      .ilw-page-switcher {
        position: relative;
        width: fit-content;
        margin: 0 0 clamp(1rem, 2vw, 1.5rem) 0;
        z-index: 5;
      }

      .ilw-page-switch-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "Superglue", sans-serif;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: 1.5px solid rgba(255,255,255,0.3);
        padding: 7px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(10px);
        color: white;
        cursor: pointer;
        transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
      }

      .ilw-page-switch-btn:hover {
        background: rgba(255,255,255,0.22);
      }

      .ilw-page-switch-caret {
        font-size: 9px;
        line-height: 1;
        transition: transform 0.2s;
        font-style: normal;
      }

      .ilw-page-switcher.open .ilw-page-switch-btn {
        background: #00bfff;
        box-shadow: 0 0 24px rgba(0,191,255,0.5);
      }

      .ilw-page-switcher.open .ilw-page-switch-caret {
        transform: rotate(180deg);
      }

      .ilw-page-switch-menu {
        position: absolute;
        top: calc(100% + 10px);
        left: 0;
        transform: translateY(-8px);
        list-style: none;
        margin: 0;
        padding: 8px;
        min-width: 220px;
        border-radius: 14px;
        background: rgba(15,15,18,0.92);
        backdrop-filter: blur(14px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.4);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s, transform 0.2s;
        z-index: 20;
      }

      .ilw-page-switcher.open .ilw-page-switch-menu {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      .ilw-page-switch-menu li {
        font-family: "Superglue", sans-serif;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255,255,255,0.85);
        padding: 10px 14px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        list-style: none;
      }

      .ilw-page-switch-menu li:hover {
        background: rgba(255,255,255,0.12);
        color: white;
      }

      .ilw-page-switch-menu li.active {
        background: #00bfff;
        color: white;
      }

      /* ── INTRO BOX ── */
      .ilw-intro {
        position: relative;
        width: min(680px, 100%);
        margin: 0 auto clamp(2rem, 4vw, 3.5rem) auto;
        border-radius: 18px;
        overflow: visible;
        padding: clamp(2rem, 4vw, 3.5rem);
        box-shadow: 0 28px 80px rgba(0,0,0,0.28);
      }

      .ilw-intro-bg {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 80%;
        height: 110%;
        transform: translate(-50%, -50%) scale(1.7);
        object-fit: fill;
        z-index: 0;
        opacity: 0.96;
        pointer-events: none;
        border-radius: 18px;
      }

      .ilw-intro-inner {
        position: relative;
        z-index: 2;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .ilw-intro-top { display: flex; flex-direction: column; }

      .ilw-intro-kicker {
        font-family: "Superglue", sans-serif;
        font-size: 11px;
        color: #00b7ff;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin: 0 0 12px 0;
      }

      .ilw-intro-heading {
        font-family: "Superglue", sans-serif;
        font-size: clamp(22px, 2.8vw, 38px);
        line-height: 0.88;
        color: #111;
        text-transform: uppercase;
        margin: 0 0 20px 0;
      }

      .ilw-intro-sub {
        margin: 0;
        font-size: clamp(0.85rem, 1vw, 1rem);
        line-height: 1.85;
        color: #333;
        border-left: 4px solid #00bfff;
        padding-left: clamp(0.85rem, 1vw, 1.1rem);
      }

      .ilw-intro-divider {
        width: 100%;
        height: 1px;
        background: rgba(0,0,0,0.12);
      }

      .ilw-intro-bottom { display: flex; flex-direction: column; gap: 10px; }

      .ilw-intro-label {
        font-family: "Superglue", sans-serif;
        font-size: clamp(0.75rem, 1vw, 0.95rem);
        letter-spacing: 0.14em;
        color: #008bb8;
        text-transform: uppercase;
        margin: 0;
      }

      .ilw-intro-body {
        margin: 0;
        font-size: clamp(0.95rem, 1vw, 1rem);
        line-height: 1.9;
        color: #1d1d1d;
      }

      /* ── CATEGORY BAR ── */
      .ilw-catbar {
        display: flex;
        flex-wrap: wrap;
        gap: clamp(0.75rem, 1.5vw, 1.25rem);
        margin: clamp(4rem, 8vw, 6rem) auto clamp(2rem, 4vw, 3rem);
        width: min(720px, 100%);
        justify-content: center;
      }

      .ilw-catbtn {
        font-family: "Superglue", sans-serif;
        font-size: clamp(0.75rem, 1vw, 0.95rem);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: none;
        padding: clamp(10px, 1vw, 16px) clamp(14px, 2vw, 22px);
        border-radius: 999px;
        background: rgba(255,255,255,0.18);
        backdrop-filter: blur(10px);
        color: white;
        cursor: pointer;
        transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
      }

      .ilw-catbtn:hover {
        transform: translateY(-2px);
        background: rgba(255,255,255,0.3);
      }

      .ilw-catbtn.active {
        background: #00bfff;
        box-shadow: 0 0 24px rgba(0,191,255,0.5);
      }

      /* ── WORK GROUPS (desktop) ── */
      .ilw-group { display: none; }
      .ilw-group.visible { display: block; }

      .ilw-group-title {
        font-family: "Superglue", sans-serif;
        font-size: clamp(24px, 3vw, 44px);
        color: white;
        text-transform: uppercase;
        margin: 0 0 6px 0;
      }

      .ilw-group-desc {
        font-size: 14px;
        color: rgba(255,255,255,0.85);
        line-height: 1.8;
        margin: 0 0 28px 0;
      }

      /* ── GRID ── */
      .ilw-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
      }

      .ilw-item {
        position: relative;
        aspect-ratio: 3 / 4;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.3s, box-shadow 0.3s;
      }

      .ilw-item:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 24px 48px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.15);
      }

      .ilw-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .ilw-item-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: flex-end;
        padding: 16px;
        background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 45%, transparent 70%);
      }

      .ilw-item-label {
        font-family: "Superglue", sans-serif;
        color: white;
        font-size: 13px;
        text-transform: uppercase;
      }

      .ilw-item.clicking {
        transform: scale(1.07);
        transition: transform 0.1s ease !important;
        box-shadow: 0 0 0 2px rgba(255,255,255,0.4), 0 24px 48px rgba(0,0,0,0.4);
      }

      /* ── DESKTOP / MOBILE SWITCH ── */
      .ilw-mobile-only { display: none; }

      /* ── MODAL ── */
      .ilw-modal {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #000;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s;
        overflow: hidden;
      }

      .ilw-modal.active {
        opacity: 1;
        pointer-events: auto;
      }

      body.ilw-modal-open {
        overflow: hidden;
      }

      html.ilw-modal-open {
        overflow: hidden;
      }

      .ilw-modal-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 20px;
        width: 100%;
        height: 100%;
        position: relative;
      }

      .ilw-modal-controls {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-shrink: 0;
      }

      .ilw-modal-counter {
        font-family: "Superglue", sans-serif;
        font-size: 12px;
        color: rgba(255,255,255,0.55);
        letter-spacing: 0.1em;
        white-space: nowrap;
        min-width: 60px;
        text-align: center;
      }

      .ilw-nav {
        background: rgba(255,255,255,0.12);
        border: none;
        color: white;
        font-size: 28px;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 0.2s, transform 0.2s;
        backdrop-filter: blur(8px);
      }

      .ilw-nav:hover {
        background: rgba(255,255,255,0.25);
        transform: scale(1.1);
      }

      .ilw-nav:disabled {
        opacity: 0.25;
        cursor: default;
        transform: none;
      }

      .ilw-close {
        position: absolute;
        top: 18px;
        right: 18px;
        background: rgba(255,255,255,0.15);
        border: none;
        color: white;
        font-size: 16px;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        transition: background 0.2s, transform 0.2s;
        z-index: 10001;
      }

      .ilw-close:hover {
        background: rgba(255,255,255,0.3);
        transform: scale(1.1);
      }

      /* ── DESKTOP MODAL: 3-image sliding track ── */
      .ilw-modal-viewport {
        position: relative;
        width: 100%;
        overflow: hidden;
      }

      .ilw-modal-track {
        display: flex;
        width: 300%;
        transform: translateX(-33.3333%);
      }

      .ilw-modal-slide {
        flex: 0 0 33.3333%;
        width: 33.3333%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .ilw-modal-img {
        display: block;
        max-width: 80vw;
        max-height: 78vh;
        width: auto;
        height: auto;
        border-radius: 10px;
        box-shadow: 0 0 80px rgba(0,0,0,0.75);
        user-select: none;
        -webkit-user-drag: none;
        touch-action: pan-y;
      }

      /* ── MOBILE MODAL ── */
      .ilw-modal-stage-mobile {
        position: relative;
        width: 100%;
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .ilw-modal-img-mobile {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        max-width: 92vw;
        max-height: 75vh;
        width: auto;
        height: auto;
        border-radius: 10px;
        box-shadow: 0 0 80px rgba(0,0,0,0.75);
        user-select: none;
        -webkit-user-drag: none;
        touch-action: pan-y;
        opacity: 0;
      }

      .ilw-modal-img-mobile.is-current {
        opacity: 1;
      }

      /* ── TABLET ── */
      @media (max-width: 1024px) {
        .ilw-wrap { padding-top: 60px; }
        .ilw-intro, .ilw-catbar { width: 100%; }
        .ilw-intro { padding: 28px 24px; }
        .ilw-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
        .ilw-modal-img { max-width: 92vw; }
        .ilw-nav { width: 40px; height: 40px; font-size: 20px; }
      }

      @media (hover: hover) and (pointer: fine) {
        .portfolio-btn-wrapper:hover { transform: scale(1.05); }
        .portfolio-btn-wrapper:hover .btn-slow { opacity: 1; }
      }

      /* ── MOBILE ── */
      @media (max-width: 768px) {
        html, body,
        .page-transition-content,
        main {
          overflow-y: auto !important;
          height: auto !important;
          max-height: none !important;
        }

        .ilw-hero {
          min-height: 100svh;
          height: auto;
          overflow: visible;
        }

        .ilw-wrap { padding: 72px 1rem 40px; }

        /* hide title on mobile — dropdown takes its place */
        .ilw-title {
          display: none;
        }

        /* dropdown acts as the page title on mobile — bigger + more breathing room */
        .ilw-page-switcher {
          margin: 0 0 2.5rem 0;
        }

        .ilw-page-switch-btn {
          font-size: 1.25rem;
          padding: 10px 18px;
          gap: 10px;
        }

        .ilw-page-switch-caret {
          font-size: 11px;
        }

        /* box: visible on sides/bottom, clipped only at the top edge */
        .ilw-intro {
          width: 100%;
          margin-left: auto;
          margin-right: auto;
          padding: 24px 18px;
          overflow: visible;
          clip-path: inset(-20px -100vw -100vw -100vw);
          box-shadow: 0 28px 80px rgba(0,0,0,0.35);
        }

        /* bg image: keep the same working scale as desktop */
        .ilw-intro-bg {
          width: 80%;
          height: 110%;
          transform: translate(-50%, -50%) scale(1.7);
          border-radius: 18px;
        }

        .ilw-catbar { padding: 0; width: 100%; gap: 0.75rem; }

        .ilw-grid {
          grid-template-columns: repeat(2, 1fr) !important;
          gap: 12px !important;
        }
        .ilw-item {
          border-radius: 16px;
          margin: 0;
          overflow: hidden;
        }

        .ilw-nav { display: none; }

        .ilw-modal-inner { height: 100%; padding: 24px 0; }

        .ilw-desktop-only { display: none !important; }
        .ilw-mobile-only  { display: block !important; }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <div class="ilw-hero">

        <video class="ilw-bg-video" autoplay muted loop playsinline preload="metadata">
          <source src="/portfoliobannerani.webm" type="video/webm" />
        </video>

        <div class="ilw-wrap">

          <div class="ilw-page-switcher">
            <button id="ilwPageSwitchBtn" class="ilw-page-switch-btn" aria-haspopup="listbox" aria-expanded="false">
              <span id="ilwPageSwitchLabel">Illustrative Works</span>
              <span class="ilw-page-switch-caret">▼</span>
            </button>
            <ul id="ilwPageSwitchMenu" class="ilw-page-switch-menu" role="listbox">
              <li role="option" data-href="/portfolio/illustrative" class="active">Illustrative</li>
              <li role="option" data-href="/portfolio/non-illustrative">Non-Illustrative</li>
              <li role="option" data-href="/tarot">Tarot</li>
              <li role="option" data-href="/portfolio/upcoming">Upcoming</li>
            </ul>
          </div>

          <h1 class="ilw-title">ILLUSTRATIVE<br />WORKS</h1>

          <div class="ilw-intro">
            <img class="ilw-intro-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
            <div class="ilw-intro-inner">
              <div class="ilw-intro-top">
                <p class="ilw-intro-kicker">Illustration Archive</p>
                <h2 class="ilw-intro-heading">Visual<br />Storytelling</h2>
                <p class="ilw-intro-sub">
                Character illustration, branding, concept art, commissioned works.
                </p>
              </div>
              <div class="ilw-intro-divider"></div>
              <div class="ilw-intro-bottom">
                <p class="ilw-intro-label">About This Collection</p>
                <p class="ilw-intro-body">
                  This is a collection of my illustrative works
                  spanning concept art, creature design, fantasy illustrations,
                  commissioned projects, all which display my passion for visual storytelling.
                </p>
                <p class="ilw-intro-body">
                  I love telling a story with my art and I firmly beleive that anything that is designed has the ability to tell a complex narrative without a single word.
                </p>
              </div>
            </div>
          </div>

          <div class="ilw-catbar">
            {illustrativeWorkGroups.map((group, i) => (
              <button
                class={`ilw-catbtn${i === 0 ? ' active' : ''}`}
                data-id={group.id}
              >
                {group.title}
              </button>
            ))}
          </div>

          <!-- DESKTOP GRID -->
          <div class="ilw-desktop-only">
            {illustrativeWorkGroups.map((group, i) => (
              <div
                class={`ilw-group${i === 0 ? ' visible' : ''}`}
                data-group={group.id}
              >
                <h2 class="ilw-group-title">{group.title}</h2>
                <p class="ilw-group-desc">{group.description}</p>
                <div class="ilw-grid">
                  {group.works.map((work, index) => (
                    <div
                      class="ilw-item"
                      data-src={work.src}
                      data-alt={work.alt}
                      data-index={index}
                    >
                      <img src={work.src} alt={work.alt} loading="lazy" />
                      <div class="ilw-item-overlay">
                        <span class="ilw-item-label">{group.title} #{index + 1}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <!-- MOBILE GRID -->
          <div class="ilw-mobile-only">
            <div id="ilw-grid-container-mobile"></div>
          </div>

        </div>
      </div>
    </main>

    <!-- DESKTOP MODAL -->
    <div id="ilwModal" class="ilw-modal ilw-desktop-only">
      <button id="ilwClose" class="ilw-close" aria-label="Close">&#x2715;</button>
      <div class="ilw-modal-inner">
        <div class="ilw-modal-viewport">
          <div id="ilwTrack" class="ilw-modal-track">
            <div class="ilw-modal-slide">
              <img id="ilwImgPrev" class="ilw-modal-img" src="" alt="" />
            </div>
            <div class="ilw-modal-slide">
              <img id="ilwImgCurrent" class="ilw-modal-img" src="" alt="" />
            </div>
            <div class="ilw-modal-slide">
              <img id="ilwImgNext" class="ilw-modal-img" src="" alt="" />
            </div>
          </div>
        </div>
        <div class="ilw-modal-controls">
          <button id="ilwPrev" class="ilw-nav" aria-label="Previous">&#8592;</button>
          <span id="ilwCounter" class="ilw-modal-counter"></span>
          <button id="ilwNext" class="ilw-nav" aria-label="Next">&#8594;</button>
        </div>
      </div>
    </div>

    <!-- MOBILE MODAL -->
    <div id="ilwModalMobile" class="ilw-modal ilw-mobile-only">
      <button id="ilwCloseMobile" class="ilw-close" aria-label="Close">&#x2715;</button>
      <div class="ilw-modal-inner">
        <div class="ilw-modal-stage-mobile">
          <img id="ilwModalImgMobileA" class="ilw-modal-img-mobile" src="" alt="" />
          <img id="ilwModalImgMobileB" class="ilw-modal-img-mobile" src="" alt="" />
        </div>
        <div class="ilw-modal-controls">
          <button id="ilwPrevMobile" class="ilw-nav" aria-label="Previous">&#8592;</button>
          <span id="ilwCounterMobile" class="ilw-modal-counter"></span>
          <button id="ilwNextMobile" class="ilw-nav" aria-label="Next">&#8594;</button>
        </div>
      </div>
    </div>

    <!-- DESKTOP SCRIPT -->
    <script>
      const modal       = document.getElementById('ilwModal') as HTMLElement;
      const closeBtn     = document.getElementById('ilwClose') as HTMLButtonElement;
      const track        = document.getElementById('ilwTrack') as HTMLElement;
      const imgPrev      = document.getElementById('ilwImgPrev') as HTMLImageElement;
      const imgCurrent   = document.getElementById('ilwImgCurrent') as HTMLImageElement;
      const imgNext      = document.getElementById('ilwImgNext') as HTMLImageElement;
      const counter      = document.getElementById('ilwCounter') as HTMLElement;
      const prevBtn      = document.getElementById('ilwPrev') as HTMLButtonElement;
      const nextBtn      = document.getElementById('ilwNext') as HTMLButtonElement;
      const bgVideo      = document.querySelector('.ilw-bg-video') as HTMLVideoElement | null;

      interface WorkItem {
        src: string | undefined;
        alt: string | undefined;
      }

      let currentGroup: WorkItem[] = [];
      let currentIndex = 0;
      let isAnimating = false;
      let didSwipe = false;

      const SLIDE_MS = 280;
      const imageCache = new Map<string, HTMLImageElement>();

      function preload(src: string | undefined): Promise<void> {
        if (!src) return Promise.resolve();
        if (imageCache.has(src)) return Promise.resolve();
        return new Promise((resolve) => {
          const im = new Image();
          im.onload = () => resolve();
          im.onerror = () => resolve();
          im.src = src;
          imageCache.set(src, im);
        });
      }

      function preloadAround(index: number): Promise<void[]> {
        const targets = [
          currentGroup[index - 1]?.src,
          currentGroup[index]?.src,
          currentGroup[index + 1]?.src,
        ];
        return Promise.all(targets.map(preload));
      }

      function setSlideSources(index: number): void {
        const prev = index > 0 ? currentGroup[index - 1] : null;
        const curr = currentGroup[index];
        const next = index < currentGroup.length - 1 ? currentGroup[index + 1] : null;
        imgPrev.src = prev?.src ?? '';
        imgPrev.alt = prev?.alt ?? '';
        imgCurrent.src = curr?.src ?? '';
        imgCurrent.alt = curr?.alt ?? '';
        imgNext.src = next?.src ?? '';
        imgNext.alt = next?.alt ?? '';
      }

      function showImage(index: number): void {
        currentIndex = index;
        setSlideSources(index);
        counter.textContent = `${currentIndex + 1} / ${currentGroup.length}`;
        prevBtn.disabled = currentIndex === 0;
        nextBtn.disabled = currentIndex === currentGroup.length - 1;
        track.style.transition = 'none';
        track.style.transform = 'translateX(-33.3333%)';
        preloadAround(index);
      }

      function slideTo(direction: 'left' | 'right'): void {
        if (isAnimating) return;
        const targetIndex = direction === 'left' ? currentIndex + 1 : currentIndex - 1;
        if (targetIndex < 0 || targetIndex > currentGroup.length - 1) { snapBack(); return; }
        const targetSrc = direction === 'left' ? imgNext.src : imgPrev.src;
        isAnimating = true;
        const startSlide = () => {
          const targetTransform = direction === 'left' ? '-66.6667%' : '0%';
          track.style.transition = `transform ${SLIDE_MS}ms ease-out`;
          track.style.transform = `translateX(${targetTransform})`;
          setTimeout(() => { showImage(targetIndex); isAnimating = false; }, SLIDE_MS);
        };
        if (targetSrc) { preload(targetSrc).then(startSlide); } else { startSlide(); }
      }

      function snapBack(): void {
        isAnimating = true;
        track.style.transition = `transform ${SLIDE_MS}ms ease-out`;
        track.style.transform = 'translateX(-33.3333%)';
        setTimeout(() => { isAnimating = false; }, SLIDE_MS);
      }

      function openModal(group: WorkItem[], index: number): void {
        currentGroup = group;
        preloadAround(index).then(() => {
          showImage(index);
          modal.classList.add('active');
          const scrollY = window.scrollY;
          document.body.style.top = `-${scrollY}px`;
          document.body.dataset.scrollY = String(scrollY);
          document.body.classList.add('ilw-modal-open');
          bgVideo?.pause();
        });
      }

      function closeModal(): void {
        modal.classList.remove('active');
        document.body.classList.remove('ilw-modal-open');
        const scrollY = parseInt(document.body.dataset.scrollY || '0', 10);
        document.body.style.top = '';
        window.scrollTo(0, scrollY);
        bgVideo?.play().catch(() => {});
        setTimeout(() => { imgPrev.src = ''; imgCurrent.src = ''; imgNext.src = ''; }, 300);
      }

      document.querySelectorAll<HTMLElement>('.ilw-catbtn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll<HTMLElement>('.ilw-catbtn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const id = btn.dataset.id;
          document.querySelectorAll<HTMLElement>('.ilw-group').forEach(g => {
            g.classList.toggle('visible', g.dataset.group === id);
          });
        });
      });

      document.querySelectorAll<HTMLElement>('.ilw-group').forEach(group => {
        const items = Array.from(group.querySelectorAll<HTMLElement>('.ilw-item'));
        const groupData: WorkItem[] = items.map(el => ({ src: el.dataset.src, alt: el.dataset.alt }));
        items.forEach((item, index) => {
          item.addEventListener('click', () => openModal(groupData, index));
        });
      });

      prevBtn.addEventListener('click', () => slideTo('right'));
      nextBtn.addEventListener('click', () => slideTo('left'));
      closeBtn.addEventListener('click', closeModal);

      modal.addEventListener('click', (e: MouseEvent) => {
        if (didSwipe) { didSwipe = false; return; }
        const target = e.target as HTMLElement;
        if (target.closest('.ilw-modal-img, .ilw-nav, .ilw-close, .ilw-modal-counter')) return;
        closeModal();
      });

      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (!modal.classList.contains('active')) return;
        if (e.key === 'Escape') closeModal();
        if (e.key === 'ArrowLeft') slideTo('right');
        if (e.key === 'ArrowRight') slideTo('left');
      });

      let touchStartX = 0;
      let touchCurrentX = 0;
      let isSwiping = false;

      modal.addEventListener('touchstart', (e: TouchEvent) => {
        if (isAnimating) return;
        touchStartX = e.touches[0].clientX;
        touchCurrentX = touchStartX;
        isSwiping = true;
        track.style.transition = 'none';
      }, { passive: true });

      modal.addEventListener('touchmove', (e: TouchEvent) => {
        if (!isSwiping) return;
        touchCurrentX = e.touches[0].clientX;
        const diff = touchCurrentX - touchStartX;
        const atStart = currentIndex === 0 && diff > 0;
        const atEnd   = currentIndex === currentGroup.length - 1 && diff < 0;
        const resistedDiff = (atStart || atEnd) ? diff * 0.15 : diff;
        track.style.transform = `translateX(calc(-33.3333% + ${resistedDiff}px))`;
      }, { passive: true });

      modal.addEventListener('touchend', () => {
        if (!isSwiping) return;
        isSwiping = false;
        const diff = touchCurrentX - touchStartX;
        const threshold = window.innerWidth * 0.25;
        if (Math.abs(diff) > 15) didSwipe = true;
        if (diff < -threshold && currentIndex < currentGroup.length - 1) { slideTo('left'); }
        else if (diff > threshold && currentIndex > 0) { slideTo('right'); }
        else { snapBack(); }
      });
    </script>

    <!-- MOBILE SCRIPT -->
    <script define:vars={{ illustrativeWorkGroups }}>
      const modalM      = document.getElementById('ilwModalMobile');
      const imgAM       = document.getElementById('ilwModalImgMobileA');
      const imgBM       = document.getElementById('ilwModalImgMobileB');
      const counterM    = document.getElementById('ilwCounterMobile');
      const prevBtnM    = document.getElementById('ilwPrevMobile');
      const nextBtnM    = document.getElementById('ilwNextMobile');
      const closeBtnM   = document.getElementById('ilwCloseMobile');
      const containerM  = document.getElementById('ilw-grid-container-mobile');
      const bgVideoM    = document.querySelector('.ilw-bg-video');

      let currentGroupM = [];
      let currentIndexM = 0;
      let isAnimatingM = false;
      let didSwipeM = false;
      let frontEl = imgAM;
      let backEl = imgBM;

      const mobileImageCache = new Map();

      function preloadMobile(src) {
        if (!src) return Promise.resolve();
        if (mobileImageCache.has(src)) return Promise.resolve();
        return new Promise((resolve) => {
          const im = new Image();
          im.onload = () => resolve();
          im.onerror = () => resolve();
          im.src = src;
          mobileImageCache.set(src, im);
        });
      }

      function preloadAroundMobile(index) {
        return Promise.all([
          currentGroupM[index - 1]?.src,
          currentGroupM[index]?.src,
          currentGroupM[index + 1]?.src,
        ].map(preloadMobile));
      }

      function renderGroupMobile(group) {
        containerM.innerHTML = `
          <h2 class="ilw-group-title">${group.title}</h2>
          <p class="ilw-group-desc">${group.description}</p>
          <div class="ilw-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;">
            ${group.works.map((work, index) => `
              <div class="ilw-item" data-src="${work.src}" data-alt="${work.alt}" data-index="${index}" style="border-radius:16px;overflow:hidden;">
                <img src="${work.src}" alt="${work.alt}" loading="lazy" />
              </div>
            `).join('')}
          </div>
        `;
        const groupData = group.works.map(w => ({ src: w.src, alt: w.alt }));
        containerM.querySelectorAll('.ilw-item').forEach((item, index) => {
          item.addEventListener('click', () => {
            item.classList.add('clicking');
            setTimeout(() => { item.classList.remove('clicking'); openModalMobile(groupData, index); }, 120);
          });
        });
        currentGroupM = groupData;
      }

      document.querySelectorAll('.ilw-catbtn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.ilw-catbtn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const group = illustrativeWorkGroups.find(g => g.id === btn.dataset.id);
          if (group) renderGroupMobile(group);
        });
      });

      renderGroupMobile(illustrativeWorkGroups[0]);

      function showImageMobile(index) {
        currentIndexM = index;
        const item = currentGroupM[currentIndexM];
        frontEl.style.transition = 'none';
        frontEl.style.transform = 'translate(-50%, -50%)';
        frontEl.src = item?.src ?? '';
        frontEl.alt = item?.alt ?? '';
        frontEl.classList.add('is-current');
        backEl.classList.remove('is-current');
        backEl.style.transition = 'none';
        counterM.textContent = `${currentIndexM + 1} / ${currentGroupM.length}`;
        prevBtnM.disabled = currentIndexM === 0;
        nextBtnM.disabled = currentIndexM === currentGroupM.length - 1;
        preloadAroundMobile(currentIndexM);
      }

      function navigateWithSlideMobile(newIndex, direction) {
        if (isAnimatingM) return;
        const item = currentGroupM[newIndex];
        if (!item) return;
        isAnimatingM = true;
        preloadMobile(item.src).then(() => {
          const enterFrom = direction === 'left' ? '100%' : '-100%';
          const exitTo = direction === 'left' ? '-100%' : '100%';
          backEl.src = item.src ?? '';
          backEl.alt = item.alt ?? '';
          backEl.style.transition = 'none';
          backEl.style.transform = `translate(calc(-50% + ${enterFrom}), -50%)`;
          backEl.classList.add('is-current');
          void backEl.offsetWidth;
          requestAnimationFrame(() => {
            frontEl.style.transition = 'transform 0.2s ease-out, opacity 0.2s ease-out';
            backEl.style.transition = 'transform 0.2s ease-out';
            frontEl.style.transform = `translate(calc(-50% + ${exitTo}), -50%)`;
            backEl.style.transform = 'translate(-50%, -50%)';
            setTimeout(() => {
              frontEl.classList.remove('is-current');
              currentIndexM = newIndex;
              counterM.textContent = `${currentIndexM + 1} / ${currentGroupM.length}`;
              prevBtnM.disabled = currentIndexM === 0;
              nextBtnM.disabled = currentIndexM === currentGroupM.length - 1;
              preloadAroundMobile(currentIndexM);
              const tmp = frontEl; frontEl = backEl; backEl = tmp;
              isAnimatingM = false;
            }, 200);
          });
        });
      }

      function openModalMobile(group, index) {
        currentGroupM = group;
        const scrollY = window.scrollY;
        preloadAroundMobile(index).then(() => {
          showImageMobile(index);
          modalM.classList.add('active');
          document.documentElement.classList.add('ilw-modal-open');
          document.body.classList.add('ilw-modal-open');
          document.body.dataset.scrollY = String(scrollY);
          if (bgVideoM) bgVideoM.pause();
        });
      }

      function closeModalMobile() {
        const scrollY = parseInt(document.body.dataset.scrollY || '0', 10);
        modalM.classList.remove('active');
        document.documentElement.classList.remove('ilw-modal-open');
        document.body.classList.remove('ilw-modal-open');
        if (bgVideoM) bgVideoM.play().catch(() => {});
        requestAnimationFrame(() => {
          window.scrollTo(0, scrollY);
        });
        setTimeout(() => {
          imgAM.src = ''; imgBM.src = '';
          imgAM.classList.remove('is-current'); imgBM.classList.remove('is-current');
          frontEl = imgAM; backEl = imgBM;
        }, 300);
      }

      prevBtnM.addEventListener('click', () => { if (currentIndexM > 0) navigateWithSlideMobile(currentIndexM - 1, 'right'); });
      nextBtnM.addEventListener('click', () => { if (currentIndexM < currentGroupM.length - 1) navigateWithSlideMobile(currentIndexM + 1, 'left'); });
      closeBtnM.addEventListener('click', closeModalMobile);

      modalM.addEventListener('click', (e) => {
        if (didSwipeM) { didSwipeM = false; return; }
        if (e.target.closest('.ilw-modal-img-mobile, .ilw-nav, .ilw-close, .ilw-modal-counter')) return;
        closeModalMobile();
      });

      document.addEventListener('keydown', (e) => {
        if (!modalM.classList.contains('active')) return;
        if (e.key === 'Escape') closeModalMobile();
        if (e.key === 'ArrowLeft' && currentIndexM > 0) navigateWithSlideMobile(currentIndexM - 1, 'right');
        if (e.key === 'ArrowRight' && currentIndexM < currentGroupM.length - 1) navigateWithSlideMobile(currentIndexM + 1, 'left');
      });

      let touchStartXM = 0, touchCurrentXM = 0, isSwipingM = false;

      modalM.addEventListener('touchstart', (e) => {
        if (isAnimatingM) return;
        touchStartXM = e.touches[0].clientX;
        touchCurrentXM = touchStartXM;
        isSwipingM = true;
        frontEl.style.transition = 'none';
      }, { passive: true });

      modalM.addEventListener('touchmove', (e) => {
        if (!isSwipingM) return;
        touchCurrentXM = e.touches[0].clientX;
        const diff = touchCurrentXM - touchStartXM;
        const atStart = currentIndexM === 0 && diff > 0;
        const atEnd   = currentIndexM === currentGroupM.length - 1 && diff < 0;
        frontEl.style.transform = `translate(calc(-50% + ${(atStart || atEnd) ? diff * 0.15 : diff}px), -50%)`;
      }, { passive: true });

      modalM.addEventListener('touchend', () => {
        if (!isSwipingM) return;
        isSwipingM = false;
        const diff = touchCurrentXM - touchStartXM;
        const threshold = window.innerWidth * 0.25;
        if (Math.abs(diff) > 15) didSwipeM = true;
        if (diff < -threshold && currentIndexM < currentGroupM.length - 1) { navigateWithSlideMobile(currentIndexM + 1, 'left'); }
        else if (diff > threshold && currentIndexM > 0) { navigateWithSlideMobile(currentIndexM - 1, 'right'); }
        else { frontEl.style.transition = 'transform 0.25s ease'; frontEl.style.transform = 'translate(-50%, -50%)'; }
      });
    </script>

    <!-- PAGE SWITCHER SCRIPT -->
    <script>
      const pageSwitcher   = document.querySelector('.ilw-page-switcher') as HTMLElement;
      const pageSwitchBtn  = document.getElementById('ilwPageSwitchBtn') as HTMLButtonElement;
      const pageSwitchMenu = document.getElementById('ilwPageSwitchMenu') as HTMLElement;

      function closePageSwitcher(): void {
        pageSwitcher.classList.remove('open');
        pageSwitchBtn.setAttribute('aria-expanded', 'false');
      }

      pageSwitchBtn.addEventListener('click', (e: MouseEvent) => {
        e.stopPropagation();
        const isOpen = pageSwitcher.classList.toggle('open');
        pageSwitchBtn.setAttribute('aria-expanded', String(isOpen));
      });

      pageSwitchMenu.querySelectorAll<HTMLElement>('li').forEach(li => {
        li.addEventListener('click', () => {
          const href = li.dataset.href;
          if (href) window.location.href = href;
        });
      });

      document.addEventListener('click', (e: MouseEvent) => {
        if (!pageSwitcher.contains(e.target as Node)) closePageSwitcher();
      });

      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') closePageSwitcher();
      });
    </script>

    <Footer />
  </body>
</html>