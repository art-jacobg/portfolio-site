---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const tarotCards = Array.from({ length: 22 }, (_, i) => i);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Portfolio Tarot | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: 'Vipnagorgialla Bd', sans-serif;
        background: #000;
        overflow-x: hidden;
      }

      /* =========================
         HERO
      ========================== */

      .hero-container {
        position: relative;
        width: 100%;
        min-height: 100vh;
      }

      .hero-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.65) contrast(1.15) saturate(1.2) hue-rotate(210deg);
        z-index: 0;
      }

      .hero-content {
        position: relative;
        z-index: 2;
        width: min(1400px, 92vw);
        margin: 0 auto;
        padding: 10rem 0 6rem;
      }

      /* =========================
         TITLE
      ========================== */

      .page-title {
        font-family: "JAVATEXT";
        font-size: clamp(3.5rem, 7vw, 7rem);
        color: white;
        margin: 0 0 2rem 0;
        line-height: 0.9;
        text-transform: uppercase;
        max-width: 900px;
        text-shadow: 0 0 25px rgba(255,255,255,0.08);
      }

      /* =========================
         DESCRIPTION BLOCKS
      ========================== */

      .description-wrap {
        display: grid;
        grid-template-columns: 1fr 0.1fr;
        gap: 3rem;
        margin-bottom: 4rem;
        font-family: "JAVATEXT";
     
      }

      .description {
        color: white;
        font-size: clamp(1.3rem, 1.1vw, 1.1rem);
        line-height: 1.7;
        opacity: 0.9;
      }

      /* =========================
         GRID
      ========================== */

      .tarot-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 2.5rem;
        margin-top: 3rem;
      }

      .tarot-card {
        width: 100%;
        aspect-ratio: 3 / 5;
        cursor: pointer;
        transition: transform 0.25s ease;
      }

      .tarot-card:hover {
        transform: translateY(-6px) scale(1.03);
      }

      .tarot-card:active {
        transform: scale(0.97);
      }

      .tarot-card img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 14px;
        background: white;
        box-shadow: 0 15px 40px rgba(0,0,0,0.6);
      }

      /* =========================
         MODAL
      ========================== */

      .modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }

      .modal.active {
        opacity: 1;
        pointer-events: auto;
      }

      .modal-card {
        width: min(520px, 90vw);
        height: min(880px, 85vh);
        perspective: 1400px;
        transform: scale(0.92);
        transition: transform 0.35s ease;
      }

      .modal.active .modal-card {
        transform: scale(1);
      }

      .modal-inner {
        width: 100%;
        height: 100%;
        position: relative;
        transform-style: preserve-3d;
        transition: transform 0.75s ease;
      }

      .modal-card:hover .modal-inner {
        transform: rotateY(180deg);
      }

      .modal-front,
      .modal-back {
        position: absolute;
        inset: 0;
        backface-visibility: hidden;
      }

      .modal-back {
        transform: rotateY(180deg);
      }

      .modal-front img,
      .modal-back img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        background: white;
        border-radius: 12px;
        box-shadow: 0 0 90px rgba(0,0,0,0.85);
      }

      /* =========================
         MOBILE
      ========================== */

      @media (max-width: 900px) {
        .description-wrap {
          grid-template-columns: 1fr;
        }

        .page-title {
          font-size: clamp(2.8rem, 12vw, 5rem);
        }

        .tarot-grid {
          gap: 1.5rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main class="hero-container">
      <img class="hero-image" src="/portfolio banner.webp" alt="Portfolio Banner" />

      <div class="hero-content">

        <h1 class="page-title">
          The Jan 6th<br />
          Tarot
        </h1>

        <div class="description-wrap">
          <p class="description">
            Made for my senior capstone for my bachelors of design and illustration, this project is a visual retelling of the events of and leading up to January 6th using the medium of tarot.<br />
            January 6th is a long and complex subject, but once you understand what happened its impossible to come to any conclusion other than that Donald Trump and his allies attemped to subvert the will of the people and overthrow democracy through illegal means. My goal with this project was to narrativize this story into a simple, viewer friendly manner so that the crimes of our presidant are not forgotten.  
           <br /> Presented as part of a senior thesis exhibition, the physical prints function as both
            narrative sequence and conceptual critique.
          </p>
        </div>

        <div class="tarot-grid">
          {tarotCards.map((i) => (
            <div
              class="tarot-card"
              data-front={`/portfolio/tarot/${i}.webp`}
              data-back={`/portfolio/tarot/${i} back.webp`}
            >
              <img src={`/portfolio/tarot/${i}.webp`} alt={`Tarot card ${i}`} />
            </div>
          ))}
        </div>

      </div>
    </main>

    <!-- MODAL -->
    <div id="modal" class="modal">
      <div class="modal-card">
        <div class="modal-inner">
          <div class="modal-front">
            <img id="modalFront" src="" />
          </div>
          <div class="modal-back">
            <img id="modalBack" src="" />
          </div>
        </div>
      </div>
    </div>

    <script>
      const modal = document.getElementById("modal");
      const modalFront = document.getElementById("modalFront");
      const modalBack = document.getElementById("modalBack");

      document.querySelectorAll(".tarot-card").forEach(card => {
        card.addEventListener("click", () => {
          modalFront.src = card.dataset.front;
          modalBack.src = card.dataset.back;
          modal.classList.add("active");
        });
      });

      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.classList.remove("active");
          setTimeout(() => {
            modalFront.src = "";
            modalBack.src = "";
          }, 300);
        }
      });
    </script>

    <Footer />
  </body>
</html>