---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const tarotCards = Array.from({ length: 22 }, (_, i) => i);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Portfolio Tarot | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />

    <style>
      *, *::before, *::after { box-sizing: border-box; }

      html {
        font-size: 16px;
      }

      body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        background: #f5f5f5;
      }

      main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      /* ─────────────────────────────
         HERO (IDENTICAL STRUCTURE TO ILLUSTRATIVE)
      ───────────────────────────── */

      .ilw-hero {
        position: relative;
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
        background: transparent;
      }

      .ilw-bg-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        z-index: 0;
        pointer-events: none;

        /* YOUR EXACT FILTERS (UNCHANGED) */
        filter:
          sepia(1)
          saturate(2.5)
          hue-rotate(5deg)
          brightness(0.97)
          contrast(1.1);
      }

      /* CONTENT WRAP (MATCHES ILLUSTRATIVE) */
      .ilw-wrap {
        position: relative;
        z-index: 2;
        width: min(1050px, 78vw);
        margin: 0 auto;
        padding-top: 100px;
        padding-bottom: 100px;
      }

      /* TITLE */
      .ilw-title {
        font-family: "JAVATEXT";
        font-size: clamp(40px, 5.2vw, 100px);
        line-height: 0.9;
        color: white;
        margin: 0 0 2rem 0;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        text-shadow: 0 0 50px rgba(255,200,80,0.3);
      }

      /* DESCRIPTION */
      .tarot-desc {
        font-family: "JAVATEXT";
        color: white;
        font-size: clamp(1rem, 1.1vw, 1.1rem);
        line-height: 1.7;
        opacity: 0.9;
        margin: 0 0 4rem 0;
        max-width: 720px;
      }

      /* GRID */
      .tarot-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2.5rem;
        margin-top: 3rem;
      }

      .tarot-card {
        width: 100%;
        aspect-ratio: 3 / 5;
        cursor: pointer;
        transition: transform 0.25s ease;
      }

      .tarot-card:hover {
        transform: translateY(-6px) scale(1.03);
      }

      .tarot-card img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 14px;
        background: white;
      }

      /* MODAL (UNCHANGED) */
      .modal {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }

      .modal.active {
        opacity: 1;
        pointer-events: auto;
      }

      .modal-card {
        width: min(520px, 90vw);
        height: min(880px, 85vh);
        perspective: 1400px;
        transform: scale(0.92);
        transition: transform 0.35s ease;
      }

      .modal.active .modal-card {
        transform: scale(1);
      }

      .modal-inner {
        width: 100%;
        height: 100%;
        position: relative;
        transform-style: preserve-3d;
        transition: transform 0.75s ease;
      }

      .modal-card:hover .modal-inner {
        transform: rotateY(180deg);
      }

      .modal-front,
      .modal-back {
        position: absolute;
        inset: 0;
        backface-visibility: hidden;
      }

      .modal-back {
        transform: rotateY(180deg);
      }

      .modal-front img,
      .modal-back img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        background: white;
        border-radius: 12px;
      }

      /* MOBILE */
      @media (max-width: 900px) {
        .ilw-wrap { padding-top: 60px; }

        .ilw-title {
          font-size: clamp(2.8rem, 12vw, 5rem);
        }

        .tarot-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 1.5rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>

      <!-- SAME HERO STRUCTURE AS ILLUSTRATIVE -->
      <div class="ilw-hero">

        <video class="ilw-bg-video" autoplay muted loop playsinline>
          <source src="/portfoliobannerani.webm" type="video/webm" />
        </video>

        <div class="ilw-wrap">

          <h1 class="ilw-title">
            The Jan 6th<br />
            Tarot
          </h1>

          <p class="tarot-desc">
            Made for my senior capstone for my bachelors of design and illustration, this project is a visual retelling of the events of and leading up to January 6th using the medium of tarot.<br /><br />
            January 6th is a long and complex subject, but once you understand what happened its impossible to come to any conclusion other than that Donald Trump and his allies attempted to subvert the will of the people and overthrow democracy through illegal means.
          </p>

          <div class="tarot-grid">
            {tarotCards.map((i) => (
              <div
                class="tarot-card"
                data-front={`/portfolio/tarot/${i}.webp`}
                data-back={`/portfolio/tarot/${i} back.webp`}
              >
                <img src={`/portfolio/tarot/${i}.webp`} alt={`Tarot card ${i}`} loading="lazy" />
              </div>
            ))}
          </div>

        </div>
      </div>

    </main>

    <!-- MODAL -->
    <div id="modal" class="modal">
      <div class="modal-card">
        <div class="modal-inner">
          <div class="modal-front">
            <img id="modalFront" />
          </div>
          <div class="modal-back">
            <img id="modalBack" />
          </div>
        </div>
      </div>
    </div>

    <script>
      const modal = document.getElementById("modal");
      const modalFront = document.getElementById("modalFront");
      const modalBack = document.getElementById("modalBack");

      document.querySelectorAll(".tarot-card").forEach(card => {
        card.addEventListener("click", () => {
          modalFront.src = card.dataset.front;
          modalBack.src = card.dataset.back;
          modal.classList.add("active");
        });
      });

      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.classList.remove("active");
          modalFront.src = "";
          modalBack.src = "";
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          modal.classList.remove("active");
          modalFront.src = "";
          modalBack.src = "";
        }
      });
    </script>

    <Footer />
  </body>
</html>