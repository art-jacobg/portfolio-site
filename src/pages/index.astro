---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="preload" href="/main image.webp" as="image" fetchpriority="high" />

    <style>
      /* Reset */
      body {
        margin: 0;
        background: white;
        font-family: sans-serif;
      }

      /* HERO IMAGE */
      .hero {
        position: relative;
      }

      .hero img {
        width: 200%;
        height: auto;
        display: block;
      }

      /* HERO OVERLAY */
      .banner-gif {
        position: absolute;
        top: 38%;
        left: 10%;
        width: min(24vw, 5625px);
        max-width: 260px;
        z-index: 2;
        pointer-events: none;
      }

      /* TEXT OVERLAY (DESKTOP) */
      .gordillo-box {
        position: absolute;
        top: 20%;
        left: 5%;
        max-width: 500px;
        color: white;
        text-shadow: 0 3px 12px rgba(160, 51, 51, 0.6);
      }

      .gordillo-box h3 {
        margin: 0 0 0.5rem 0;
        font-size: 2rem;
        font-family: "Overload Burn", sans-serif;
        font-weight: 900;
      }

      .gordillo-box p {
        margin: 0;
        line-height: 1.5;
        font-family: "Overload Burn", sans-serif;
      }

      /* MOBILE FIX */
      @media (max-width: 720px) {
        .gordillo-box {
          position: static;
          max-width: 90%;
          margin: 1.5rem auto;
          text-align: center;
          color: black;
          text-shadow: none;
        }

        .banner-gif {
          left: 110%;
          top: 18%;
          transform: translateX(-50%);
          width: min(48vw, 0px);
        }
      }

      /* MAIN CONTENT */
      main {
        padding: 2rem 1rem;
        max-width: 800px;
        margin: 0 auto;
      }
    </style>
  </head>

  <body>
    <Header />

    <!-- HERO -->
    <div class="hero">
      <img src="/main image.webp" alt="Main Banner" />
      <img class="banner-gif" src="/wizardjuice.gif" alt="Wizard Juice overlay" />
    </div>

    <main>
      <!-- Your future content -->
    </main>

    <Footer />
  </body>
</html>
