---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

    <style>
    body {
  margin: 0;
  background: none;
  font-family: sans-serif;
}

      .hero {
        position: relative;
      }

      .hero video {
  width: 100%;
  height: auto;
  display: block;
}

      .banner-gif {
        position: absolute;
        top: 38%;
        left: 10%;
        width: min(24vw, 5625px);
        max-width: 260px;
        z-index: 2;
        pointer-events: none;
      }

      .gordillo-box {
        position: absolute;
        top: 20%;
        left: 5%;
        max-width: 500px;
        color: white;
        text-shadow: 0 3px 12px rgba(160, 51, 51, 0.6);
      }

      .gordillo-box h3 {
        margin: 0 0 0.5rem 0;
        font-size: 2rem;
        font-family: "Overload Burn", sans-serif;
        font-weight: 900;
      }

      .gordillo-box p {
        margin: 0;
        line-height: 1.5;
        font-family: "Overload Burn", sans-serif;
      }

      @media (max-width: 720px) {
        .gordillo-box {
          position: static;
          max-width: 90%;
          margin: 1.5rem auto;
          text-align: center;
          color: black;
          text-shadow: none;
        }

        .banner-gif {
          left: 10%;
          top: 18%;
          transform: translateX(-50%);
          width: min(48vw, 0px);
        }
      }

      main {
  margin: 0;
  padding: 0;

}
    </style>
  </head>

  <body>
    <Header />

    <div class="hero">
      <video autoplay muted loop playsinline>
        <source src="/homepageani.webm" type="video/webm" />
      </video>
    </div>

    <main>
      <!-- Your future content -->
    </main>

    <Footer />
  </body>
</html>