---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      main {
        flex: 1;
        overflow: hidden;
      }

      .hero-video {
        display: block;
        width: 100%;
        height: auto;
      }

      .hero-video.desktop {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .hero-video.mobile {
        display: none;
      }

      ::view-transition-old(page) {
        animation: fade-out 800ms ease-in both;
      }

      ::view-transition-new(page) {
        animation: fade-in 800ms ease-out both;
      }

      @keyframes fade-out {
        from { opacity: 1; }
        to   { opacity: 0; }
      }

      @keyframes fade-in {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      @media (max-width: 768px) {
  body {
    height: auto;
    min-height: 100vh;
  }

  main {
    overflow: visible;
    flex: 1;
  }

  .page-transition-content {
    width: 100%;
    position: relative;
  }

  .hero-video.desktop {
    display: none;
  }

  .hero-video.mobile {
    display: block;
    position: relative;
    width: 100%;
    height: calc(90svh - -10px); /* was 120px, bumped up to close the gap */
    object-fit: cover;
    object-position: center 48%;  /* shift content upward within the frame */
    left: 0;
    top: 0;
    transform: scale(1.05);       /* slight scale up */
    transform-origin: center top;
  }
}
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-transition-content">
        <video class="hero-video desktop" autoplay muted loop playsinline preload="metadata">
          <source src="/homepageani.webm" type="video/webm" />
        </video>
        <video class="hero-video mobile" autoplay muted loop playsinline preload="metadata">
          <source src="/indexmobileanimation.webm" type="video/webm" />
        </video>
      </div>
    </main>
    <Footer />
  </body>
</html>