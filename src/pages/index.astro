---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        width: 100%;
        overflow-x: hidden;
        overflow-y: auto;
      }

      .hero-video {
        display: block;
        width: 100%;
        height: auto;
      }

::view-transition-old(page) {
  animation: fade-out 800ms ease-in both;
}

::view-transition-new(page) {
  animation: fade-in 800ms ease-out both;
}

@keyframes fade-out {
  from { opacity: 1; }
  to   { opacity: 0; }
}

@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
      .hero-video.mobile {
        display: none;
      }

      .hero-video.desktop {
        display: block;
      }

      @media (max-width: 768px) {
        .hero-video.desktop {
          display: none;
        }

        .hero-video.mobile {
          display: block;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-transition-content">
        <video class="hero-video desktop" autoplay muted loop playsinline preload="metadata">
          <source src="/homepageani.webm" type="video/webm" />
        </video>
        <video class="hero-video mobile" autoplay muted loop playsinline preload="metadata">
          <source src="/indexmobileanimation.webm" type="video/webm" />
        </video>
      </div>
    </main>
    <Footer />
  </body>
</html>