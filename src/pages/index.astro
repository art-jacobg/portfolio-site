---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preload" href="/main image.png" as="image" fetchpriority="high" />
		<ViewTransitions />
		<style>
			body {
				background: white;
			}

			.full-box { width: 100%; display: block; position: relative; overflow: hidden; }
			.full-box .bg { width: 100%; height: 100%; object-fit: cover; display: block; }
			.gordillo-box { position: absolute; left: 4%; top: 18%; background: rgba(255,255,255,0.9); padding: 1.25rem 1.5rem; border-radius: 8px; box-shadow: 0 8px 30px rgba(0,0,0,0.12); max-width: 46%; }
			.gordillo-box h3 { font-family: "Overload Burn", sans-serif; margin: 0 0 0.25rem 0; font-size: 2.2rem; }
			.gordillo-box p { margin: 0; }
			.hero-container {
				margin: 0;
				padding: 0;
				width: 100%;
			}
			.hero-image {
				width: 100%;
				height: auto;
				display: block;
				margin: 0;
				padding: 0;
			}
			main {
				background: white;
				margin: 0;
				padding: 3em 1em;
				width: 100%;
				max-width: 100%;
			}
			@media (max-width: 720px) {
				main {
					padding: 2em 1em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="hero-container">
			<img class="hero-image" src="/main image.png" alt="Main Banner" />
		</div>
		<main>
			<section class="full-box" id="fullBox">
				<img class="bg" src="/about page banner.png" alt="Full banner" />
				<div class="gordillo-box" id="gordilloBox">
					<h3>Gordillo</h3>
					<p>Short descriptive text placed under the left side of the G.</p>
				</div>
			</section>
		</main>

		<script>
			// Make the full box fill the remaining viewport below the hero image
			document.addEventListener('DOMContentLoaded', () => {
				const hero = document.querySelector('.hero-image');
				const box = document.getElementById('fullBox');
				if (!hero || !box) return;
				function sizeBox() {
					const heroBottom = hero.getBoundingClientRect().bottom;
					const remaining = Math.max(window.innerHeight - heroBottom, window.innerHeight * 0.4);
					box.style.height = remaining + 'px';
				}
				sizeBox();
				window.addEventListener('resize', sizeBox);
			});
		</script>
		<Footer />
	</body>
</html>
