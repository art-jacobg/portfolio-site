---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        width: 100%;
        min-height: 100%;
        overflow-x: hidden;
        overflow-y: auto;
        margin: 0;
        padding: 0;
        background: #fff;
      }

      video.hero {
        display: block;
        width: 100vw;
        height: auto;
        object-fit: contain;
        object-position: center center;
        background: transparent;
      }

      video.hero.mobile {
        display: none;
      }

      @media (max-width: 768px) {
        video.hero.desktop {
          display: none;
        }

        video.hero.mobile {
          display: block;
        }
      }

      @media (max-width: 480px) {
        video.hero {
          height: min(100svh, 100vh);
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <div class="page-transition-content">
      <video class="hero desktop" autoplay muted loop playsinline preload="metadata">
        <source src="/homepageani.webm" type="video/webm" />
      </video>
    <video class="hero mobile" autoplay muted loop playsinline preload="metadata">
      <source src="/indexmobileanimation.webm" type="video/webm" />
    </video>
    </div>
    <Footer />
  </body>
</html>