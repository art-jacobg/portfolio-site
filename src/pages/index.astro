---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preload" href="/main image.png" as="image" fetchpriority="high" />
		<ViewTransitions />
		<style>
			body {
				background: white;
			}

			.extra-sections { max-width: 1200px; margin: 2.5rem auto; padding: 0 1rem; display: grid; gap: 2.25rem; }
			.extra-row img { width: 100%; height: auto; display: block; border-radius: 8px; box-shadow: 0 6px 18px rgba(0,0,0,0.08); }
			@media (min-width: 1280px) { .extra-sections { max-width: 1400px; } }
			.hero-container {
				margin: 0;
				padding: 0;
				width: 100%;
			}
			.hero-image {
				width: 100%;
				height: auto;
				display: block;
				margin: 0;
				padding: 0;
			}
			main {
				background: white;
				margin: 0;
				padding: 3em 1em;
				width: 100%;
				max-width: 100%;
			}
			@media (max-width: 720px) {
				main {
					padding: 2em 1em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="hero-container">
			<img class="hero-image" src="/main image.png" alt="Main Banner" />
		</div>
		<main>
			<section class="extra-sections">
				<section class="extra-row">
					<img src="/about page banner.png" alt="About banner" />
				</section>
				<section class="extra-row">
					<img src="/portfolio banner.png" alt="Portfolio banner" />
				</section>
				<section class="extra-row">
					<img src="/about page banner.png" alt="About banner" />
				</section>
			</section>
		</main>
		<Footer />
	</body>
</html>
