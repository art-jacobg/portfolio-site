---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="About | Jacob Gordillo" description="The artist in question" />
    <style>
  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    padding: 0 !important;
    overflow-x: hidden;
  }

  .page-title {
    font-family: "Superglue";
    font-size: 6rem;
    color: white;
    position: absolute;
    top: 1rem;
    left: clamp(-23.3rem, -21.3vw, -20.3rem);
    margin: 0;
    z-index: 20;
    pointer-events: none;
  }

  main {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .about-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
  }

  .about-bg-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    z-index: 0;
    pointer-events: none;
    min-height: 100%;
  }
  .about-bg-video.desktop { display: block; }
  .about-bg-video.mobile  { display: none; }

  .about-bg-overlay { display: none; }

  .about-wrap {
    position: relative;
    z-index: 2;
    width: min(1000px, 75vw);
    margin: 0 auto;
    padding-top: 90px;
    padding-bottom: 450px;
    animation: fadeIn 500ms ease 200ms forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .about-animbox {
    position: relative;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    padding: 4rem 2.5rem 3.5rem;
    overflow: visible;
    margin-top: 3rem;
  }

  .about-animbox-bg {
    position: absolute;
    top: 0;
    left: -1.5%;
    right: -1.5%;
    bottom: -1rem;
    width: 103%;
    max-width: 104%;
    height: 105%;
    object-fit: fill;
    z-index: 0;
    border-radius: 10px;
    pointer-events: none;
    transform: scaleX(1.28) scaleY(1.55);
    transform-origin: center;
  }

  .about-columns {
    position: relative;
    z-index: 1;
    margin-top: 6rem;
    display: grid;
    grid-template-columns: 1fr 2px 1fr;
    gap: 0 2.5rem;
    align-items: stretch;
  }

  .about-divider {
    background: rgba(0, 0, 0, 0.2);
    align-self: stretch;
    border-radius: 2px;
  }

  .about-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-section-title {
    font-family: "Superglue";
    font-size: 1.3rem;
    letter-spacing: 0.12em;
    color: #0e3947;
    margin: 0 0 0.4rem;
    text-transform: uppercase;
  }

  .about-dots { display: flex; gap: 0.4rem; }

  .about-name {
    font-family: "Superglue", sans-serif;
    font-size: clamp(1.4rem, 2.2vw, 2.2rem);
    color: #111;
    margin: 0;
    line-height: 1.1;
  }

  .about-subtitle {
    font-size: clamp(0.72rem, 0.95vw, 1.5rem);
    color: #333;
    line-height: 1.6;
    margin: 0;
    border-left: 3px solid #0099cc;
    padding-left: 0.75rem;
    font-family: "Overload Burn";
  }

  .about-col p.body {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.8;
    color: #222;
    font-family: "JAVATEXT";
  }

  .about-rule {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.12);
    margin: 0.25rem 0;
    display: block !important;
  }

  .about-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0;
    padding: 0;
    list-style: none;
    font-family: "Overload Burn";
  }

  .about-skills li {
    font-size: 1.1rem;
    background: rgba(0, 153, 204, 0.12);
    border: 1px solid rgba(0, 153, 204, 0.35);
    border-radius: 3px;
    padding: 0.25rem 0.5rem;
    color: #111;
  }

  .about-education {
    font-size: clamp(0.68rem, 0.85vw, 0.88rem);
    color: #333;
    line-height: 1.55;
    margin: 0;
    font-family: "JAVATEXT";
    border-left: 2px solid rgba(0,153,204,0.4);
    padding-left: 0.85rem;
  }

  .about-education strong {
    display: block;
    color: #111;
    font-size: 1rem;
    font-family: "Overload Burn";
  }

  .about-experience-item {
    border-left: 2px solid rgba(0,153,204,0.4);
    padding-left: 0.85rem;
    margin: 0;
    font-family: "JAVATEXT";
  }

  .about-experience-item strong {
    display: block;
    font-size: 1rem;
    color: #111;
    margin-bottom: 0.15rem;
    font-family: "Overload Burn";
  }

  .about-experience-item span {
    font-size: 0.85rem;
    color: #666;
    display: block;
    margin-bottom: 0.25rem;
    font-family: "Overload Burn";
  }

  .about-experience-item p {
    font-size: 0.88rem !important;
    color: #333;
    margin: 0;
    line-height: 1.6;
  }

  .mob-section { position: static; }
  .mob-section-bg { display: none; }

  footer {
    position: relative;
    z-index: 10;
  }

  /* ══════════════════════════════════════
     MOBILE ONLY — single clean block
  ══════════════════════════════════════ */
  @media (max-width: 768px) {
    html, body,
    .page-transition-content,
    main {
      overflow-y: auto !important;
      height: auto !important;
      max-height: none !important;
    }

    .about-rule { display: none !important; }

    .about-bg-video.desktop { display: none; }

    .about-bg-video.mobile {
  display: block;
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: fill;
  z-index: 0;
}
    .about-hero {
  position: relative;
  height: auto;
  min-height: 100%;    /* grows with content */
  overflow: hidden;    /* clips the video to the container */
}

    .page-title {
      font-size: clamp(2.8rem, 11vw, 4rem);
      position: relative;
      top: auto;
      left: auto;
      padding: 0.75rem 1rem 0;
      display: block;
    }

    .about-wrap {
      width: min(92vw, 680px);
      padding-top: 0.75rem;
      padding-bottom: 3rem;
    }

    .about-animbox {
      padding: 0;
      margin-top: 4rem;
      display: block;
      background: none;
    }

    .about-animbox-bg { display: none; }

    .about-columns {
      display: flex;
      flex-direction: column;
      gap: 10rem;
      margin-top: 0;
    }

    .about-divider { display: none; }

    .about-col { gap: 7rem; }

    .mob-section {
      position: relative;
      padding: 2rem 3rem 2rem 4.5rem;
      overflow: visible;
      margin-bottom: 6rem;
    }

    .about-col:first-child .mob-section:first-child {
      padding-top: 3rem;
      padding-bottom: 3rem;
      clip-path: inset(0 -50% -50% -50%);
    }

    .mob-section-bg {
      display: block;
      position: absolute;
      top: 50%;
      left: 50%;
      width: 175%;
      height: 170%;
      object-fit: fill;
      z-index: 0;
      pointer-events: none;
      transform: translate(-50%, -50%);
      transform-origin: center;
    }

    .about-col:first-child .mob-section:first-child .mob-section-bg {
      width: 185%;
      height: 180%;
    }

    .mob-section > *:not(.mob-section-bg) {
      position: relative;
      z-index: 1;
    }

    .mob-section .about-experience-item,
    .mob-section .about-education,
    .mob-section .about-skills {
      margin-left: 0;
    }

    .about-name {
      font-size: clamp(1.1rem, 4.8vw, 1.5rem);
      line-height: 1.15;
    }

    .about-subtitle { font-size: clamp(0.78rem, 3.2vw, 0.95rem); }
    .about-section-title { font-size: 1rem; letter-spacing: 0.08em; }

    .about-col p.body {
      font-size: clamp(0.85rem, 3.2vw, 1rem);
      line-height: 1.7;
    }

    .about-education,
    .about-experience-item p {
      font-size: clamp(0.8rem, 3vw, 0.9rem) !important;
      line-height: 1.55;
    }

    .about-education strong,
    .about-experience-item strong {
      font-size: clamp(0.85rem, 3.2vw, 0.95rem);
    }

    .about-experience-item span { font-size: clamp(0.72rem, 2.8vw, 0.82rem); }

    .about-skills li {
      font-size: clamp(0.72rem, 2.8vw, 0.85rem);
      padding: 0.2rem 0.5rem;
    }
  }
</style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-transition-content">
        <div class="about-hero">

          <video class="about-bg-video desktop" autoplay muted loop playsinline preload="metadata">
            <source src="/aboutbackround.webm" type="video/webm" />
          </video>
          <video class="about-bg-video mobile" autoplay muted loop playsinline preload="metadata">
            <source src="/aboutmobile.webm" type="video/webm" />
          </video>

          <div class="about-wrap">
            <h1 class="page-title">ABOUT</h1>

            <div class="about-animbox">
              <img class="about-animbox-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />

              <div class="about-columns">

                <!-- LEFT COLUMN -->
                <div class="about-col">

                  <!-- SECTION: Identity + Artist Statement -->
                  <div class="mob-section">
                    <img class="mob-section-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
                    <div class="about-dots">
                      <span></span><span></span><span></span>
                    </div>
                    <h2 class="about-name">Jacob<br/>Gordillo</h2>
                    <p class="about-subtitle">
                      Designer &amp; Editorial Illustrator<br/>
                      Herron School of Art &amp; Design<br/>
                      Indianapolis, Indiana
                    </p>
                    <hr class="about-rule" />
                    <p class="about-section-title">Artist Statement</p>
                    <p class="body">
                      Hi, I'm Jacob, a designer who graduated from the Herron School of Art
                      and Design with a bachelor's in Design and Illustration. I'm passionate about visual
                      storytelling, branding, and communication, with proficency in a variety of professional design tools and mediums with an understanding of how to tailor designs and construct compelling narratives for specific audiences. I love bringing stories to life!
                    </p>
                    <p class="body">
                      Over the past eight years, as I've become more politically active, I've realized the
                      importance of furthering democratic ideals. Seeing the opposition trample on the
                      foundational ideas of Western liberalism has only fueled my passion for political action. I've done volunteer canvassing and doorknocking and I'm eager to engange in further activism and professional work!
                      I believe design is one of the most powerful tools we have to connect with and
                      communicate our values to voters and the broader populace.
                    </p>
                  </div>

                  <hr class="about-rule" />
                </div>

                <!-- DIVIDER -->
                <div class="about-divider"></div>

                <!-- RIGHT COLUMN -->
                <div class="about-col">

                  <!-- SECTION: Education -->
                  <div class="mob-section">
                    <img class="mob-section-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
                    <p class="about-section-title">Education</p>
                    <p class="about-education">
                      <strong>BFA — Drawing &amp; Illustration</strong>
                      Herron School of Art and Design,<br/>
                      IU Indianapolis — 2025
                    </p>
                    <p class="about-education" style="margin-top:0.5rem">
                      <strong>AS — General Studies</strong>
                      Ivytech Community College,<br/>
                      Bloomington, IN — 2022
                    </p>
                  </div>

                  <hr class="about-rule" />

                  <!-- SECTION: Experience -->
                  <div class="mob-section">
                    <img class="mob-section-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
                    <p class="about-section-title">Experience</p>
                    <div class="about-experience-item">
                      <strong>Progressive Victory — Cincinnati, OH</strong>
                      <span>Political Canvassing &amp; Voter Registration · Feb 2024</span>
                      <p>
                        Door knocking, canvassing, and voter registration. Developed communication skills and
                        hands-on experience working directly with voters and organizers.
                      </p>
                    </div>
                    <div class="about-experience-item" style="margin-top:0.75rem">
                      <strong>Progressive Victory — Milwaukee, WI</strong>
                      <span>Political Canvassing &amp; Door Knocking · Oct 2024</span>
                      <p>
                        More experience working with voters and organizers, managing my own workload and accomplishing tasks
                        efficiently and independently.
                      </p>
                    </div>
                  </div>

                  <hr class="about-rule" />

                  <!-- SECTION: Skills -->
                  <div class="mob-section">
                    <img class="mob-section-bg" src="/box animation slow1.webp" alt="" aria-hidden="true" />
                    <p class="about-section-title">Skills</p>
                    <ul class="about-skills">
                      <li>Adobe Illustrator</li>
                      <li>Photoshop</li>
                      <li>InDesign</li>
                      <li>Vegas Movie Studio</li>
                      <li>Clip Studio Paint</li>
                      <li>Microsoft Office</li>
                      <li>Branding</li>
                      <li>Character Design</li>
                      <li>Editorial Illustration</li>
                      <li>Political Advertising</li>
                      <li>Narrative storytelling</li>
                    </ul>
                  </div>

                </div>

              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>