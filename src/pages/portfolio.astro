---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Portfolio | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <link rel="preload" href="/portfolio banner 2.webp" as="image" fetchpriority="high" />

    <style>
      /* ─────────────────────────────────────────────────────────────
         HERO
      ───────────────────────────────────────────────────────────── */
      .hero-container {
        position: relative;
        width: 100%;
      }

      .hero-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        z-index: 0;
        display: block;
      }

      .page-title {
        font-family: "Superglue";
        font-size: 6rem;
        color: white;
        position: absolute;
        top: 1rem;
        left: -10rem;
        margin: 0;
        z-index: 20;
        pointer-events: none;
        mix-blend-mode: normal;
      }

      /* ─────────────────────────────────────────────────────────────
         OVERLAY GRID
      ───────────────────────────────────────────────────────────── */
      .portfolio-overlay {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 2.5fr 1fr;
        grid-template-rows: repeat(3, 260px);
        gap: 3px;
        padding: 8rem 1rem 3rem;
        box-sizing: border-box;
        max-width: 1400px;
        margin: 0 auto;
        right: 3.75rem;
      }

      /* ─────────────────────────────────────────────────────────────
         SECTION BASE
      ───────────────────────────────────────────────────────────── */
      .portfolio-section {
        display: flex;
        align-items: center;
        gap: 0.1rem;
        overflow: hidden;
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
        padding: 3.8rem;
        box-sizing: border-box;
        border-radius: 4px;
      }

      /* ─────────────────────────────────────────────────────────────
         LARGE CARD — Tarot
      ───────────────────────────────────────────────────────────── */
      .card--tarot {
        grid-column: 1;
        grid-row: 1 / 4;
        background-image: url('/box animation slow1.webp');
        flex-direction: row;
        align-items: center;
        gap: 2rem;
        padding: 8.5rem;
         padding-top: 10rem;
      }

      .card--tarot .card-image {
        flex-shrink: 0;
      }

      .card--tarot .card-image img {
        width: auto;
        max-width: 220px;
        max-height: calc(3 * 260px - 5rem);
        height: auto;
        display: block;
        object-fit: contain;
      }

      .card--tarot .card-text {
        flex: 1;
        min-width: 0;

      }

      .card--tarot .card-text h2 {
        font-size: clamp(1.8rem, 3vw, 3.4rem);
        line-height: 1.1;
        margin: 0 0 0.45rem;
      }

      /* tarot button: inline in the text flow */
.portfolio-btn--tarot {
  text-decoration: none;
  display: inline-block;
  margin-top: 0.1rem;
  align-self: flex-start;
  
}

/* tarot button wrapper — edit independently here */
.portfolio-btn--tarot .portfolio-btn-wrapper {
  width: 440px;
  height: 82px;
  
}
.portfolio-btn--tarot .portfolio-btn-text {
  font-size: 0.8rem; /* change this value */
  
}

      /* ─────────────────────────────────────────────────────────────
         SMALL CARDS — right column
         position: relative anchors the absolute button inside each card
      ───────────────────────────────────────────────────────────── */
      .card--illustrative {
        grid-column: 2;
        grid-row: 1;
        background-image: url('/box animation slow2.webp');
        flex-direction: column;
        align-items: flex-start;
        position: relative;
      }

      .card--non-illustrative {
        grid-column: 2;
        grid-row: 2;
        background-image: url('/box animation slow4.webp');
        flex-direction: column;
        align-items: flex-start;
        position: relative;
        left: 3.75rem;
      }

      .card--upcoming {
        grid-column: 2;
        grid-row: 3;
        background-image: url('/box animation slow3.webp');
        flex-direction: column;
        align-items: flex-start;
        position: relative;
      }

      /* right column button: pinned to bottom-right of its card */
      .portfolio-btn--small {
        text-decoration: none;
        display: inline-block;
        position: absolute;
        bottom: 3.5rem;
        right: 4.2rem;
      }

      /* image thumbnails in small cards */
    /* make sure the card is the anchor */
.card--illustrative,
.card--non-illustrative,
.card--upcoming {
  position: relative; /* already set, just confirming */
}

/* remove the shared translateY from thumbnails and go absolute */
.card--illustrative .card-image img {
  transform: none;
  position: absolute;
   bottom: 3.7rem;
  left: 3.7rem;
  width: auto%;
  height: 50%;
  object-fit: cover;
}

.card--non-illustrative .card-image img {
  transform: none;
  position: absolute;
   bottom: 3rem;
  left: 3.2rem;
  width: auto;
  height: 60%;
  object-fit: cover;
}

.card--upcoming .card-image img {
  transform: none;
  position: absolute;
   bottom: 3.7rem;
  left: 3.7rem;
  width: auto%;
  height: 50%;
  object-fit: cover;     
      }

      /* ─────────────────────────────────────────────────────────────
         CARD TEXT
      ───────────────────────────────────────────────────────────── */
      .card-text {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  min-width: 0;
  /* remove the transform from here */
}

/* now each card's text is individually controllable */
.card--illustrative .card-text {
    transform: translateY(0.4rem) translateX(6rem);
       padding-right:5.2rem;
       
}

.card--non-illustrative .card-text {
      transform: translateY(0.6rem) translateX(5rem);
      padding-right:4.5rem;
}

.card--upcoming .card-text {
      transform: translateY(1rem) translateX(6rem);
      padding-right:6rem;
}
    

      .card-text h2 {
        margin: 0;
        font-size: 0.9rem;
        line-height: 1;
        font-family: "Superglue";
        
      }

      .card-text p {
        font-size: 0.9rem;
        line-height: 1.45;
        color: #444;
        margin: 0;
      }

      /* ─────────────────────────────────────────────────────────────
         VIDEO BUTTON — shared wrapper styles
      ───────────────────────────────────────────────────────────── */
      .portfolio-btn-wrapper {
        position: relative;
        width: 160px;
        height: 42px;
        border-radius: 4px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease;
      }

      .portfolio-btn-wrapper:hover {
        transform: scale(1.05);
      }

      .portfolio-btn-wrapper video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: fill;
      }

      .btn-fast { opacity: 1; z-index: 1; }
      .btn-slow { opacity: 0; z-index: 2; transition: opacity 0.25s ease; }
      .portfolio-btn-wrapper:hover .btn-slow { opacity: 1; }

      .portfolio-btn-text {
        position: relative;
        z-index: 3;
        display: inline-block;
        transform: scaleY(1.7) translateY(2px);
        color: white;
        font-size: 0.55rem;
        font-family: "Superglue";
        
      }

      /* ─────────────────────────────────────────────────────────────
         MOBILE
      ───────────────────────────────────────────────────────────── */
      @media (max-width: 768px) {
        .hero-image {
          display: none;
        }

        .hero-container {
          background: #b8e8f0;
        }

        .page-title {
          font-size: 3rem;
          top: 0.5rem;
        }

        .portfolio-overlay {
          display: flex;
          flex-direction: column;
          gap: 0.75rem;
          padding: 6rem 1rem 2rem;
          grid-template-columns: unset;
          grid-template-rows: unset;
        }

        .card--tarot,
        .card--illustrative,
        .card--non-illustrative,
        .card--upcoming {
          grid-column: unset;
          grid-row: unset;
          width: 100%;
          flex-direction: column;
          align-items: flex-start;
          min-height: 200px;
        }

        /* revert absolute button to normal flow on mobile */
        .portfolio-btn--small {
          position: static;
          margin-top: 0.5rem;
        }

        .card--tarot .card-image img {
          max-width: 120px;
          max-height: 200px;
        }

        .card--tarot .card-text h2 {
          font-size: 1.7rem;
        }

        .card--illustrative .card-image img,
        .card--non-illustrative .card-image img,
        .card--upcoming .card-image img {
          height: 80px;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <div class="hero-container">
      <img class="hero-image" src="/portfolio banner 2.webp" alt="Portfolio banner" />

      <div class="portfolio-overlay">
        <h1 class="page-title">PORTFOLIO</h1>

        <!-- ── TAROT (large, left) ─────────────────────────────── -->
        <section class="portfolio-section card--tarot">
          <div class="card-image">
            <img src="/portfolio/tarot/0.webp" alt="Tarot card preview" />
          </div>
          <div class="card-text">
            <h2>January 6th Tarot Cards</h2>
            <p>
              My goal was to narrativize the events surrounding January 6th to effectively convey that it wasn't just a riot, but
              Donald Trump's genuine attempt to subvert our democracy. Including the full collection both front and back.
            </p>
            <a href="/tarot" class="portfolio-btn--tarot">
              <div class="portfolio-btn-wrapper">
                <video src="/button portfolio slow.webm" class="btn-fast" muted autoplay loop playsinline></video>
                <video src="/button portfolio fast.webm" class="btn-slow" muted autoplay loop playsinline></video>
                <span class="portfolio-btn-text">See Collection</span>
              </div>
            </a>
          </div>
        </section>

        <!-- ── ILLUSTRATIVE (top right) ───────────────────────── -->
        <section class="portfolio-section card--illustrative">
          <div class="card-image">
            <img src="/portfolio/illustrative/concept art5.webp" alt="Illustrative work preview" />
          </div>
          <div class="card-text">
            <h2>Illustrative Works</h2>
            <p>Character art, editorial pieces, and concept visuals.</p>
          </div>
          <a href="/portfolio/illustrative" class="portfolio-btn--small">
            <div class="portfolio-btn-wrapper">
              <video src="/button home slow.webm" class="btn-fast" muted autoplay loop playsinline></video>
              <video src="/button home fast.webm" class="btn-slow" muted autoplay loop playsinline></video>
              <span class="portfolio-btn-text">Explore</span>
            </div>
          </a>
        </section>

        <!-- ── NON-ILLUSTRATIVE (mid right) ───────────────────── -->
        <section class="portfolio-section card--non-illustrative">
          <div class="card-image">
            <img src="/wizardjuice.gif" alt="Non-illustrative work preview" />
          </div>
          <div class="card-text">
            <h2>Non-Illustrative Works</h2>
            <p>Branding, motion, and layout-driven work.</p>
          </div>
          <a href="/portfolio/non-illustrative" class="portfolio-btn--small">
            <div class="portfolio-btn-wrapper">
              <video src="/button about slow.webm" class="btn-fast" muted autoplay loop playsinline></video>
              <video src="/button about fast.webm" class="btn-slow" muted autoplay loop playsinline></video>
              <span class="portfolio-btn-text">See Work</span>
            </div>
          </a>
        </section>

        <!-- ── UPCOMING (bottom right) ────────────────────────── -->
        <section class="portfolio-section card--upcoming">
          <div class="card-image">
            <img src="/portfolio/upcoming/swordcomps.webp" alt="Upcoming project preview" />
          </div>
          <div class="card-text">
            <h2>Upcoming Projects</h2>
            <p>Sneak peeks at projects in progress.</p>
          </div>
          <a href="/portfolio/upcoming" class="portfolio-btn--small">
            <div class="portfolio-btn-wrapper">
              <video src="/button contact slow.webm" class="btn-fast" muted autoplay loop playsinline></video>
              <video src="/button contact fast.webm" class="btn-slow" muted autoplay loop playsinline></video>
              <span class="portfolio-btn-text">See More</span>
            </div>
          </a>
        </section>

      </div>
    </div>

    <Footer />
  </body>
</html>