---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Portfolio | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <link rel="preload" href="/portfolio banner.png" as="image" fetchpriority="high" />
    <ViewTransitions />
    <style>
      /* Hero Banner */
      .hero-container {
        margin: 0;
        padding: 0;
        width: 100%;
        position: relative;
        background: white;
      }
      .hero-image {
        width: 100%;
        height: auto;
        display: block;
        margin: 0;
        padding: 0;
      }
      .page-title {
        font-family: "Superglue";
        font-size: 5.5rem;
        color: white;
        position: absolute;
        top: 2rem;
        left: 2rem;
        margin: 0;
        z-index: 10;
      }

      /* Featured Tarot Panel - top right of hero */
      .tarot-feature {
        position: absolute;
        top: 12%;
        right: 48.3%;
        pointer-events: auto;
        z-index: 0;
        display: flex;
        justify-content: flex-end;
      }
      .tarot-feature-content {
    padding: 2rem 2.5rem;       /* bigger padding */
    max-width: 1100px;          /* increase the max width */
    border-radius: 16px;        /* optional: slightly bigger corners */
    box-shadow: 0 10px 25px rgba(0,0,0,0.2); /* optional: stronger shadow */
      }
      .tarot-feature-preview img {
    width: 240px;   /* increase width from 180px */
    border-radius: 10px;
    object-fit: cover;
      }
      .tarot-feature-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: .5rem;
      }
      .tarot-feature-text h2 {
        font-family: "JAVATEXT";
        font-size: 4.5rem;
        margin: 0;
        color: #222;
      }
      .tarot-feature-text p {
        font-size: 1.1rem;
        color: #444;
        margin: 0.25rem 0;
      }
      .btn {
        display: inline-block;
        margin-top: 0.75rem;
        padding: 0.75rem 1.6rem;
        background: #1fb3ee;
        color: white;
        font-weight: bold;
        text-align: center;
        border-radius: 6px;
        text-decoration: none;
        font-size: 1.1rem;
        transition: background 0.2s ease;
      }
      .btn:hover { background: #68a6ca; }

      /* Responsive adjustments */
      @media (max-width: 1024px) {
        .tarot-feature-content { flex-direction: column; align-items: center; text-align: center; }
        .tarot-feature-preview img { width: 160px; }
      }
      @media (max-width: 720px) {
        .page-title { font-size: 3rem; top: 1rem; left: 1rem; }
        .tarot-feature { top: 5%; right: 5%; }
        .tarot-feature-text h2 { font-size: 2.2rem; }
        .btn { font-size: 1rem; padding: 0.65rem 1.4rem; }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- Hero Banner -->
    <div class="hero-container">
      <img class="hero-image" src="/portfolio banner.png" alt="Portfolio Banner" />
      <h1 class="page-title">PORTFOLIO</h1>

      <!-- Featured Tarot Card Panel -->
      <section class="tarot-feature">
        <div class="tarot-feature-content">
          <div class="tarot-feature-preview">
            <img src="/portfolio/tarot/0.png" alt="January 6th Tarot cards preview" />
          </div>
          <div class="tarot-feature-text">
            <h2>January 6th Tarot Cards</h2>
            <p>Explore the full tarot card project — front and back artwork included.</p>
            <a href="tarot" class="btn">View More</a>
          </div>
        </div>
      </section>
    </div>

    <Footer />
  </body>
</html>