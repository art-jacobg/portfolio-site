---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Portfolio | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <link rel="preload" href="/portfoliobannerani.webm" as="video" fetchpriority="high" />

    <style>
      *, *::before, *::after { box-sizing: border-box; }

      body {
        margin: 0;
        padding: 0 !important;
        overflow-x: hidden;
        background: #fff;
      }

      main {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      /* ── HERO ── */
      .hero-container {
        position: relative;
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
        background: #fff;
      }

      .hero-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        z-index: 0;
        pointer-events: none;
      }

      .page-title {
        font-family: "Superglue";
        font-size: clamp(4rem, 7vw, 6rem);
        color: white;
        position: absolute;
        top: 1rem;
        left: clamp(-8rem, -6vw, -4rem);
        margin: 0;
        z-index: 20;
        pointer-events: none;
      }

      /* ── OVERLAY GRID ── */
      .portfolio-overlay {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 2.5fr 1fr;
        grid-template-rows: repeat(3, minmax(220px, 260px));
        gap: clamp(0.5rem, 1vw, 1rem);
        padding: clamp(4rem, 6vw, 8rem) 1rem 3rem;
        box-sizing: border-box;
        max-width: 1400px;
        margin: 0 auto;
      }

      .portfolio-section {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        overflow: hidden;
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
        padding: clamp(2.5rem, 4vw, 4rem);
        box-sizing: border-box;
        border-radius: 4px;
      }

      .card--tarot {
        grid-column: 1;
        grid-row: 1 / 4;
        background-image: url('/box animation slow1.webp');
        flex-direction: row;
        align-items: center;
        gap: clamp(1.5rem, 2vw, 2rem);
        padding: clamp(4rem, 5vw, 8.5rem);
        padding-top: clamp(5rem, 6vw, 10rem);
      }

      .card--tarot .card-image { flex-shrink: 0; }

      .card--tarot .card-image img {
        width: auto;
        max-width: min(220px, 35vw);
        max-height: calc(3 * 260px - 5rem);
        height: auto;
        display: block;
        object-fit: contain;
      }

      .card--tarot .card-text { flex: 1; min-width: 0; }

      .card--tarot .card-text h2 {
        font-size: clamp(1.8rem, 3vw, 3.4rem);
        line-height: 1.1;
        margin: 0 0 0.45rem;
      }

      .portfolio-btn--tarot {
        text-decoration: none;
        display: inline-block;
        margin-top: 0.1rem;
        align-self: flex-start;
      }

      .portfolio-btn--tarot .portfolio-btn-wrapper {
        width: min(440px, 70vw);
        height: clamp(68px, 7vw, 82px);
      }

      .portfolio-btn--tarot .portfolio-btn-text { font-size: clamp(0.75rem, 1.1vw, 0.8rem); }

      .card--illustrative {
        grid-column: 2;
        grid-row: 1;
        background-image: url('/box animation slow2.webp');
        flex-direction: column;
        align-items: flex-start;
        position: relative;
        padding-bottom: clamp(5rem, 6vw, 6.5rem);
      }

      .card--non-illustrative {
        grid-column: 2;
        grid-row: 2;
        background-image: url('/box animation slow4.webp');
        flex-direction: column;
        align-items: flex-start;
        position: relative;
        left: 3.75rem;
        padding-bottom: clamp(5rem, 6vw, 6.5rem);
      }

      .card--upcoming {
        grid-column: 2;
        grid-row: 3;
        background-image: url('/box animation slow3.webp');
        flex-direction: column;
        align-items: flex-start;
        position: relative;
        padding-bottom: clamp(5rem, 6vw, 6.5rem);
      }

      .portfolio-btn--small {
        text-decoration: none;
        display: inline-block;
        position: absolute;
        bottom: 3.2rem;
        right: 4.2rem;
      }

      .card--illustrative,
      .card--non-illustrative,
      .card--upcoming { position: relative; }

      .card--illustrative .card-image img,
      .card--non-illustrative .card-image img,
      .card--upcoming .card-image img {
        transform: none;
        position: absolute;
        width: auto;
        object-fit: cover;
      }

      .card--illustrative .card-image img {
        bottom: 3.7rem;
        left: 3.7rem;
        height: 50%;
      }

      .card--non-illustrative .card-image img {
        bottom: 3rem;
        left: 3.2rem;
        height: 60%;
      }

      .card--upcoming .card-image img {
        bottom: 3.7rem;
        left: 3.7rem;
        height: 50%;
      }

      .card-text {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        min-width: 0;
      }

      .card--illustrative .card-text {
        transform: translateY(-0.2rem) translateX(5.6rem);
        padding-right: 5.2rem;
      }

      .card--non-illustrative .card-text {
        transform: translateY(-0.05rem) translateX(5rem);
        padding-right: 4.5rem;
      }

      .card--upcoming .card-text {
        transform: translateY(0rem) translateX(6rem);
        padding-right: 6rem;
      }

      .card-text h2 {
        margin: 0;
        font-size: 0.9rem;
        line-height: 1;
        font-family: "Superglue";
      }

      .card-text p {
        font-size: 0.9rem;
        line-height: 1.45;
        color: #444;
        margin: 0;
      }

      .portfolio-btn-wrapper {
        position: relative;
        width: 160px;
        height: 42px;
        border-radius: 4px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease;
      }

      .portfolio-btn-wrapper:hover { transform: scale(1.05); }

      .portfolio-btn-wrapper video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: fill;
      }

      .btn-fast { opacity: 1; z-index: 1; }
      .btn-slow { opacity: 0; z-index: 2; transition: opacity 0.25s ease; }
      .portfolio-btn-wrapper:hover .btn-slow { opacity: 1; }

      .portfolio-btn-text {
        position: relative;
        z-index: 3;
        display: inline-block;
        transform: scaleY(1.7) translateY(2px);
        color: white;
        font-size: 0.55rem;
        font-family: "Superglue";
      }

      @media (max-width: 1024px) {
        .portfolio-overlay {
          grid-template-columns: 1fr;
          grid-template-rows: unset;
          padding: 6rem 1rem 2rem;
        }

        .card--tarot,
        .card--illustrative,
        .card--non-illustrative,
        .card--upcoming {
          grid-column: unset;
          grid-row: unset;
          width: 100%;
          flex-direction: column;
          align-items: flex-start;
          min-height: auto;
        }

        .card--non-illustrative { left: 0; }
        .card--illustrative .card-image img,
        .card--non-illustrative .card-image img,
        .card--upcoming .card-image img { height: 80px; }
      }

      @media (max-width: 768px) {
        .hero-container { background: #b8e8f0; }
        .page-title { font-size: clamp(3rem, 8vw, 4.2rem); top: 0.5rem; left: 1rem; }
        .portfolio-overlay { padding: 5rem 0.75rem 2rem; gap: 0.75rem; }
        .portfolio-section { padding: clamp(2rem, 4vw, 3rem); }
        .portfolio-btn--small { position: static; margin-top: 0.65rem; }
        .card--tarot .card-image img { max-width: 160px; max-height: 200px; }
        .card--tarot .card-text h2 { font-size: clamp(1.8rem, 5vw, 2.4rem); }
      }

      @media (max-width: 480px) {
        .portfolio-overlay { padding: 3.5rem 0.75rem 1.5rem; }
        .portfolio-section { padding: 1.5rem; gap: 0.5rem; }
        .card--tarot { padding: 3rem 2rem 4rem; }
        .portfolio-btn--tarot .portfolio-btn-wrapper { width: min(280px, 100%); height: clamp(56px, 9vw, 68px); }
        .portfolio-btn-text { font-size: 0.7rem; }
      }
    </style>
  </head>

  <body>
    <Header />

    <div class="page-transition-content">
      <div class="hero-container">
        <video class="hero-video" autoplay muted loop playsinline preload="metadata">
          <source src="/portfoliobannerani.webm" type="video/webm" />
        </video>

        <div class="portfolio-overlay">
        <h1 class="page-title">PORTFOLIO</h1>

        <section class="portfolio-section card--tarot">
          <div class="card-image">
            <img src="/portfolio/tarot/0.webp" alt="Tarot card preview" />
          </div>
          <div class="card-text">
            <h2>January 6th Tarot Cards</h2>
            <p>
              My goal was to narrativize the events surrounding January 6th to effectively convey that it wasn't just a riot, but
              Donald Trump's genuine attempt to subvert our democracy. Including the full collection both front and back.
            </p>
            <a href="/tarot" class="portfolio-btn--tarot">
              <div class="portfolio-btn-wrapper">
                <video src="/button portfolio slow.webm" class="btn-fast" muted autoplay loop playsinline preload="metadata"></video>
                <video src="/button portfolio fast.webm" class="btn-slow" muted autoplay loop playsinline preload="metadata"></video>
                <span class="portfolio-btn-text">See Collection</span>
              </div>
            </a>
          </div>
        </section>

        <section class="portfolio-section card--illustrative">
          <div class="card-image">
            <img src="/portfolio/illustrative/concept art5.webp" alt="Illustrative work preview" />
          </div>
          <div class="card-text">
            <h2>Illustrative Works</h2>
            <p>Character art, editorial pieces, and concept visuals.</p>
          </div>
          <a href="/portfolio/illustrative" class="portfolio-btn--small">
            <div class="portfolio-btn-wrapper">
              <video src="/button home slow.webm" class="btn-fast" muted autoplay loop playsinline preload="metadata"></video>
              <video src="/button home fast.webm" class="btn-slow" muted autoplay loop playsinline preload="metadata"></video>
              <span class="portfolio-btn-text">Explore</span>
            </div>
          </a>
        </section>

        <section class="portfolio-section card--non-illustrative">
          <div class="card-image">
            <img src="/wizardjuice.gif" alt="Non-illustrative work preview" />
          </div>
          <div class="card-text">
            <h2>Non-Illustrative Works</h2>
            <p>Branding, motion, and layout-driven work.</p>
          </div>
          <a href="/portfolio/non-illustrative" class="portfolio-btn--small">
            <div class="portfolio-btn-wrapper">
              <video src="/button about slow.webm" class="btn-fast" muted autoplay loop playsinline preload="metadata"></video>
              <video src="/button about fast.webm" class="btn-slow" muted autoplay loop playsinline preload="metadata"></video>
              <span class="portfolio-btn-text">See Work</span>
            </div>
          </a>
        </section>

        <section class="portfolio-section card--upcoming">
          <div class="card-image">
            <img src="/portfolio/upcoming/swordcomps.webp" alt="Upcoming project preview" />
          </div>
          <div class="card-text">
            <h2>Upcoming Projects</h2>
            <p>Sneak peeks at projects in progress.</p>
          </div>
          <a href="/portfolio/upcoming" class="portfolio-btn--small">
            <div class="portfolio-btn-wrapper">
              <video src="/button contact slow.webm" class="btn-fast" muted autoplay loop playsinline preload="metadata"></video>
              <video src="/button contact fast.webm" class="btn-slow" muted autoplay loop playsinline preload="metadata"></video>
              <span class="portfolio-btn-text">See More</span>
            </div>
          </a>
        </section>

      </div>
    </div>

    <Footer />
  </body>
</html>