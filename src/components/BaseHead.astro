---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = '/blog-placeholder-1.jpg' } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/Overload Burn.otf" as="font" type="font/otf" crossorigin />
<link rel="preload" href="/fonts/Superglue.otf" as="font" type="font/otf" crossorigin />
<link rel="preload" href="/fonts/JAVATEXT.TTF" as="font" type="font/ttf" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<style is:inline>
  body { opacity: 0; }

  @keyframes slide-out-left {
    0%   { transform: translateX(0); opacity: 1; filter: brightness(1) blur(0px); }
    60%  { transform: translateX(-30px); opacity: 0.6; filter: brightness(1.4) blur(0px); }
    100% { transform: translateX(-60px); opacity: 0; filter: brightness(2) blur(6px); }
  }
  @keyframes slide-out-right {
    0%   { transform: translateX(0); opacity: 1; filter: brightness(1) blur(0px); }
    60%  { transform: translateX(30px); opacity: 0.6; filter: brightness(1.4) blur(0px); }
    100% { transform: translateX(60px); opacity: 0; filter: brightness(2) blur(6px); }
  }
  @keyframes slide-in-left {
    0%   { transform: translateX(-60px); opacity: 0; filter: brightness(2) blur(6px); }
    40%  { transform: translateX(-30px); opacity: 0.6; filter: brightness(1.4) blur(0px); }
    100% { transform: translateX(0); opacity: 1; filter: brightness(1) blur(0px); }
  }
  @keyframes slide-in-right {
    0%   { transform: translateX(60px); opacity: 0; filter: brightness(2) blur(6px); }
    40%  { transform: translateX(30px); opacity: 0.6; filter: brightness(1.4) blur(0px); }
    100% { transform: translateX(0); opacity: 1; filter: brightness(1) blur(0px); }
  }
</style>

<script>
  const pageOrder: Record<string, number> = {
  '/': 0,
  '/portfolio': 1,
  '/about': 2,
  '/contact': 3,
};

const normalizePath = (href: string) => {
  const url = new URL(href, location.origin);
  const pathname = url.pathname.replace(/\/$/, '');
  return pathname === '' ? '/' : pathname;
};

document.addEventListener('DOMContentLoaded', () => {
  const direction = sessionStorage.getItem('slideDirection') ?? 'forward';
  sessionStorage.removeItem('slideDirection');

  const anim = direction === 'forward'
    ? 'slide-in-right 200ms ease-out forwards'
    : 'slide-in-left 200ms ease-out forwards';

  document.body.style.animation = anim;

  document.body.addEventListener('animationend', () => {
    document.body.style.animation = '';
    document.body.style.transform = '';
    document.body.style.opacity = '1';
  }, { once: true });

  // Safety: if animationend never fires, show the page anyway
  setTimeout(() => {
    document.body.style.animation = '';
    document.body.style.transform = '';
    document.body.style.opacity = '1';
  }, 400);

  // ... rest of click handler

  document.addEventListener('click', async (e) => {
    const link = (e.target as HTMLElement).closest('a[href]');
    if (!link) return;
    const href = link.getAttribute('href');
    if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto')) return;
    e.preventDefault();
    e.stopImmediatePropagation();

    const current = normalizePath(location.pathname);
    const target = normalizePath(href);
    const currentIndex = pageOrder[current] ?? 0;
    const targetIndex = pageOrder[target] ?? 0;
    const goingForward = targetIndex > currentIndex;

    sessionStorage.setItem('slideDirection', goingForward ? 'forward' : 'backward');

    document.body.style.animation = goingForward
      ? 'slide-out-left 200ms ease-in both'
      : 'slide-out-right 200ms ease-in both';

    await new Promise(r => setTimeout(r, 400));
    window.location.href = href;
  }, true);
});
</script>

