---
import { SITE_TITLE } from '../consts';
---

<style>
  header {
    margin: 0;
    padding: 0;
    background: white;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    line-height: 0;
  }

  nav {
    width: 100%;
    overflow: hidden;
  }

  .nav-inner {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(1.5rem, 5vw, 4rem);
    flex-wrap: nowrap;
    line-height: normal;
    padding: 0.65rem 1.5rem 0.65rem 1rem;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.4rem, 1vw, 0.75rem);
    align-items: center;
  }

  .nav-links a {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    background: transparent;
    border: none;
    line-height: 1;
  }

  .nav-links a::before,
  .nav-links a::after {
    content: none;
    display: none;
  }

  .nav-button-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    height: 82px;
    min-width: 120px;
    padding: 0 8px;
    box-sizing: border-box;
    opacity: 1;
    transform: none;
  }

  .nav-button {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 100px;
    position: absolute;
    inset: 0;
    object-fit: cover;
    z-index: 1;
    transform-origin: center;
    transform: scale(0.9);
  }

  .nav-gif {
    position: relative;
    z-index: 2;
    width: auto;
    height: 100%;
    max-height: 84px;
    display: block;
    transform: scale(0.95);
    transition: opacity 0.18s ease;
  }

  .nav-button-text {
    position: absolute;
    width: 100%;
    z-index: 10;
    font-family: "Overload Burn", sans-serif;
    font-weight: 900;
    font-size: 1.25rem;
    color: #fff;
    pointer-events: none;
    text-align: center;
    text-shadow: 0 3px 8px rgba(0,0,0,0.6);
  }

  .social-links {
    display: flex;
    gap: clamp(0.5rem, 1.5vw, 1rem);
    align-items: center;
    flex-shrink: 0;
    justify-content: center;
    margin-right: 1.5rem;
  }

  .social-links a { display: inline-flex; }

  .gif-wrapper {
    position: relative;
    width: clamp(52px, 6vw, 85px);
    height: clamp(48px, 6vw, 80px);
    overflow: hidden;
  }

  .gif {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.18s ease;
    backface-visibility: hidden;
    will-change: opacity;
    background-color: transparent;
  }

  .gif.base { opacity: 1; z-index: 1; }
  .gif.hover { opacity: 0; z-index: 2; }
  .gif-wrapper:hover .gif.hover { opacity: 1; }
  .gif-wrapper:hover .gif.base { opacity: 1; }

  /* ── HAMBURGER ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    z-index: 200;
    flex-shrink: 0;
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 3px;
    background: #0099cc;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .hamburger.is-open span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .hamburger.is-open span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

.mobile-drawer {
  display: none;
  position: fixed;
  top: 0;
  right: 0;
  width: min(300px, 80vw);
  height: 100dvh;
  z-index: 150;
  flex-direction: column;
  padding: 5rem 1.5rem 2.5rem 2.5rem;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: visible;  /* allow pseudo-element to bleed left */
  background: none;
}

.mobile-drawer::before {
  content: '';
  position: absolute;
  top: 11%;
  left: -160%;
  width: 450%;       /* much larger — becomes the height after rotation */
  height: 70%;
  background-image: url('/box animation slow1.webp');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  z-index: 0;
  pointer-events: none;
  transform: rotate(90deg);
  transform-origin: center center;
  opacity: 0;
  transition: opacity 0.2s ease;
}
.mobile-drawer.is-open::before {
  opacity: 1;
  transition: opacity 0.2s ease 0.05s;
}

.drawer-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
}


/* Make sure content stays above bg */
.drawer-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
}

  .mobile-drawer.is-open {
    transform: translateX(0);
  }

  /* Backdrop */
  .drawer-backdrop {
  display: none;        /* or display: block inside the mobile media query */
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 140;
  opacity: 0;
  transition: opacity 0.35s ease;
  backdrop-filter: blur(2px);
}

.drawer-backdrop.is-open {
  opacity: 1;
}

  /* All drawer content sits above the bg image */
  .drawer-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0;
  }

  .drawer-nav-links {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1.6rem;
  flex: 1;
  padding-top: 1rem;
}

  .drawer-nav-links a {
    display: flex;
    text-decoration: none;
    color: inherit;
    width: 100%;
    justify-content: center;
    /* prevent layout shift during drawer slide */
    will-change: auto;
  }

  .drawer-nav-links .nav-button-wrapper {
    height: 72px;
    min-width: 0;
    width: 100%;
    max-width: 260px;
    animation: none; /* no animation inside drawer */
  }

  /* Social section */
  .drawer-social-section {
    border-top: 1px solid rgba(0, 153, 204, 0.3);
    padding-top: 1.25rem;
    margin-top: 0.5rem;
  }

  .drawer-social-title {
    font-family: "Superglue", sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #0e3947;
    text-align: center;
    margin-bottom: 0.85rem;
  }

  .drawer-social {
    display: flex;
    flex-wrap: nowrap; /* keep all on one line */
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
  }

  .drawer-social a { display: inline-flex; flex-shrink: 0; }

  .drawer-social .gif-wrapper {
    width: 48px;
    height: 44px;
  }

  /* ── DESKTOP BREAKPOINTS ── */
  @media (max-width: 1024px) {
    .nav-button-wrapper { height: 78px; min-width: 108px; padding: 0 6px; }
    .nav-button { max-height: 80px; }
    .nav-gif { max-height: 72px; }
    .nav-button-text { font-size: 1.1rem; }
    .gif-wrapper { width: 62px; height: 54px; }
  }

  /* ── MOBILE ── */
  .nav-brand { display: none; }

  /* ── MOBILE DRAWER REDESIGN ── */
@media (max-width: 768px) {
  .nav-links { display: none; }
  .social-links { display: none; }

  header {
    background: transparent;
    box-shadow: none;
  }

  .nav-inner {
    justify-content: flex-end;
    padding: 0rem 1rem;
    gap: 0;
  }

  .nav-brand { display: none; }

  .hamburger {
