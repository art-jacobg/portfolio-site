  <script is:inline>
    (function () {
      const pageOrder = {
        '/': 0,
        '/portfolio': 1,
        '/about': 2,
        '/contact': 3,
      };

      const root = document.documentElement;

      const normalizePath = (href) => {
        const url = new URL(href, location.origin);
        const pathname = url.pathname.replace(/\/$/, '');
        return pathname === '' ? '/' : pathname;
      };

      const getDirection = (href) => {
        const current = normalizePath(location.pathname);
        const target = normalizePath(href);
        const currentIndex = pageOrder[current] ?? 0;
        const targetIndex = pageOrder[target] ?? 0;
        return targetIndex >= currentIndex ? 'forward' : 'backward';
      };

      document.querySelectorAll('.nav-links a[href], .drawer-nav-links a[href]').forEach((anchor) => {
        anchor.addEventListener('click', (event) => {
          if (anchor.target === '_blank' || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
          const href = anchor.getAttribute('href');
          if (!href || normalizePath(href) === normalizePath(location.pathname)) return;
          event.preventDefault();

          root.dataset.pageTransition = getDirection(href);
          const navigate = () => window.location.assign(href);

          if (document.startViewTransition) {
            document.startViewTransition(navigate);
          } else {
            navigate();
          }
        });
      });

      // ── Drawer logic ──
      const btn = document.getElementById('hamburger-btn');
      const drawer = document.getElementById('mobile-drawer');
      const backdrop = document.getElementById('drawer-backdrop');

      function openDrawer() {
        btn.classList.add('is-open');
        drawer.classList.add('is-open');
        backdrop.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
        drawer.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        btn.classList.remove('is-open');
        drawer.classList.remove('is-open');
        backdrop.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        drawer.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      btn.addEventListener('click', () => {
        btn.classList.contains('is-open') ? closeDrawer() : openDrawer();
      });

      backdrop.addEventListener('click', closeDrawer);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeDrawer();
      });

      drawer.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeDrawer);
      });
    })();
  </script>
